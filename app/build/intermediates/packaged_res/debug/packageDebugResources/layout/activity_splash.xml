<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#fff8f3">

    <!-- Doodles Container -->
    <!-- Top Left -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="restaurant"
        android:textSize="120sp"
        android:textColor="#8f4e00"
        android:alpha="0.05"
        android:rotation="-15"
        android:fontFamily="@font/material_symbols_outlined"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="48dp"
        android:layout_marginStart="48dp"/>
    
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="kitchen"
        android:textSize="80sp"
        android:textColor="#1f1b16"
        android:alpha="0.05"
        android:rotation="25"
        android:fontFamily="@font/material_symbols_outlined"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="160dp"
        android:layout_marginStart="128dp"/>

    <!-- Top Right -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="blender"
        android:textSize="100sp"
        android:textColor="#8f4e00"
        android:alpha="0.05"
        android:rotation="10"
        android:fontFamily="@font/material_symbols_outlined"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="80dp"
        android:layout_marginEnd="80dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="soup_kitchen"
        android:textSize="60sp"
        android:textColor="#1f1b16"
        android:alpha="0.05"
        android:rotation="-20"
        android:fontFamily="@font/material_symbols_outlined"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="192dp"
        android:layout_marginEnd="144dp"/>

    <!-- Bottom Left -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="local_pizza"
        android:textSize="90sp"
        android:textColor="#1f1b16"
        android:alpha="0.05"
        android:rotation="-10"
        android:fontFamily="@font/material_symbols_outlined"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="96dp"
        android:layout_marginStart="64dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="bakery_dining"
        android:textSize="70sp"
        android:textColor="#8f4e00"
        android:alpha="0.05"
        android:rotation="30"
        android:fontFamily="@font/material_symbols_outlined"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="224dp"
        android:layout_marginStart="128dp"/>

    <!-- Bottom Right -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="egg_alt"
        android:textSize="110sp"
        android:textColor="#8f4e00"
        android:alpha="0.05"
        android:rotation="15"
        android:fontFamily="@font/material_symbols_outlined"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="64dp"
        android:layout_marginEnd="96dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="local_dining"
        android:textSize="65sp"
        android:textColor="#1f1b16"
        android:alpha="0.05"
        android:rotation="-25"
        android:fontFamily="@font/material_symbols_outlined"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="192dp"
        android:layout_marginEnd="160dp"/>


    <!-- Main Content -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout
            android:id="@+id/logoContainer"
            android:layout_width="128dp"
            android:layout_height="128dp"
            android:background="@drawable/bg_logo_circle"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="restaurant_menu"
                android:textSize="72sp"
                android:textColor="#6d3a00"
                android:layout_gravity="center"
                android:fontFamily="@font/material_symbols_outlined"/>
        </FrameLayout>

        <View
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_accent_circle"
            app:layout_constraintBottom_toBottomOf="@id/logoContainer"
            app:layout_constraintEnd_toEndOf="@id/logoContainer"
            android:layout_marginEnd="-8dp"
            android:layout_marginBottom="-8dp"
            android:alpha="0.6"/>

        <TextView
            android:id="@+id/textTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CoolCook"
            android:textSize="56sp"
            android:textColor="#DC2626" 
            android:textStyle="bold"
            android:letterSpacing="-0.02"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/logoContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Trợ lý nấu ăn thông minh của bạn"
            android:textSize="18sp"
            android:textColor="#544437"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/textTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>