<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/journalCameraPreviewCard"
    android:layout_width="0dp"
    android:layout_height="0dp"
    android:layout_marginStart="@dimen/journal_outer_padding"
    android:layout_marginTop="@dimen/journal_section_gap"
    android:layout_marginEnd="@dimen/journal_outer_padding"
    android:stateListAnimator="@null"
    app:cardBackgroundColor="@color/journal_surface_dark"
    app:cardCornerRadius="@dimen/journal_preview_radius"
    app:cardElevation="0dp"
    app:layout_constraintDimensionRatio="100:118"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toBottomOf="@id/journalTopBar">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.camera.view.PreviewView
            android:id="@+id/journalPreviewView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:keepScreenOn="true"
            app:implementationMode="performance"
            app:scaleType="fillCenter" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnJournalFlash"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_gravity="start|top"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/fg_ripple_circle"
            android:stateListAnimator="@null"
            app:cardBackgroundColor="#66212123"
            app:cardCornerRadius="999dp"
            app:cardElevation="0dp">

            <TextView
                android:id="@+id/iconJournalFlash"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/material_symbols_outlined"
                android:text="flash_off"
                android:textColor="@color/journal_text_primary"
                android:textSize="20sp" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/txtJournalStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal|bottom"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="14dp"
            android:fontFamily="@font/be_vietnam_pro"
            android:gravity="center"
                android:text="Camera sẵn sàng · Vuốt xuống để xem feed"
            android:textColor="@color/journal_text_secondary"
            android:textSize="13sp" />
    </FrameLayout>

</com.google.android.material.card.MaterialCardView>
