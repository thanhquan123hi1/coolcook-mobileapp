<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_friend_invite_sheet"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="24dp"
    android:paddingEnd="24dp"
    android:paddingBottom="24dp">

    <TextView
        android:id="@+id/txtFriendSheetTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/manrope"
        android:text="Bạn bè CoolCook"
        android:textColor="#FF2B2118"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtFriendSheetSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="@font/be_vietnam_pro"
        android:text="Mở màn hình mã kết bạn để sao chép mã của bạn hoặc nhập mã của bạn bè."
        android:textColor="#B3FFFFFF"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/txtInviteLink"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:background="@drawable/bg_locket_secondary_light_button"
        android:fontFamily="@font/be_vietnam_pro"
        android:paddingStart="16dp"
        android:paddingTop="14dp"
        android:paddingEnd="16dp"
        android:paddingBottom="14dp"
        android:textColor="#FF5F4937"
        android:textSize="13sp"
        android:visibility="gone" />

    <EditText
        android:id="@+id/edtFriendInviteInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:autofillHints="none"
        android:background="@drawable/bg_locket_secondary_light_button"
        android:fontFamily="@font/be_vietnam_pro"
        android:hint="Dan link hoac ma moi cua ban vao day"
        android:inputType="textUri"
        android:maxLines="3"
        android:minHeight="54dp"
        android:paddingStart="16dp"
        android:paddingTop="14dp"
        android:paddingEnd="16dp"
        android:paddingBottom="14dp"
        android:textColor="#FF2B2118"
        android:textColorHint="#FF9A7A5F"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/btnOpenInviteInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_locket_secondary_light_button"
        android:fontFamily="@font/manrope"
        android:gravity="center"
        android:minHeight="54dp"
        android:paddingStart="18dp"
        android:paddingTop="14dp"
        android:paddingEnd="18dp"
        android:paddingBottom="14dp"
        android:text="Dan link/ma de ket ban"
        android:textColor="#FF5F4937"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/btnCreateInviteLink"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:background="@drawable/bg_locket_primary_button"
        android:fontFamily="@font/manrope"
        android:gravity="center"
        android:minHeight="54dp"
        android:paddingStart="18dp"
        android:paddingTop="14dp"
        android:paddingEnd="18dp"
        android:paddingBottom="14dp"
        android:text="Mã kết bạn"
        android:textColor="#FF111111"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/btnCopyInviteLink"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_locket_secondary_light_button"
        android:fontFamily="@font/manrope"
        android:gravity="center"
        android:minHeight="54dp"
        android:paddingStart="18dp"
        android:paddingTop="14dp"
        android:paddingEnd="18dp"
        android:paddingBottom="14dp"
        android:text="Copy link"
        android:textColor="#FF5F4937"
        android:textSize="16sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <TextView
        android:id="@+id/btnShareInviteLink"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_locket_secondary_light_button"
        android:fontFamily="@font/manrope"
        android:gravity="center"
        android:minHeight="54dp"
        android:paddingStart="18dp"
        android:paddingTop="14dp"
        android:paddingEnd="18dp"
        android:paddingBottom="14dp"
        android:text="Chia sẻ qua Messenger/Zalo/SMS"
        android:textColor="#FF5F4937"
        android:textSize="16sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <TextView
        android:id="@+id/btnFriendSheetClose"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:fontFamily="@font/manrope"
        android:gravity="center"
        android:minHeight="48dp"
        android:paddingStart="18dp"
        android:paddingTop="12dp"
        android:paddingEnd="18dp"
        android:paddingBottom="12dp"
        android:text="Đóng"
        android:textColor="#FF9A7A5F"
        android:textSize="16sp"
        android:textStyle="bold" />

</LinearLayout>
