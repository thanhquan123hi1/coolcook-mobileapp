<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/registerPanel"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:visibility="gone">

    <TextView
        style="@style/TextAppearance.Coolcook.Brand.Title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/auth_register_title"
        android:textColor="@color/primary" />

    <TextView
        style="@style/TextAppearance.Coolcook.Brand.Subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="28dp"
        android:text="@string/auth_register_subtitle" />

    <LinearLayout
        android:id="@+id/registerFields"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="18dp"
            android:orientation="vertical">

            <TextView
                style="@style/TextAppearance.Coolcook.Auth.Label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auth_full_name" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/registerNameLayout"
                style="@style/Widget.Coolcook.Auth.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/registerName"
                    style="@style/Widget.Coolcook.Auth.TextInputEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:autofillHints="name"
                    android:hint="@string/auth_hint_full_name"
                    android:imeOptions="actionNext"
                    android:importantForAutofill="yes"
                    android:inputType="textPersonName|textCapWords" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="18dp"
            android:orientation="vertical">

            <TextView
                style="@style/TextAppearance.Coolcook.Auth.Label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auth_email" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/registerEmailLayout"
                style="@style/Widget.Coolcook.Auth.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/registerEmail"
                    style="@style/Widget.Coolcook.Auth.TextInputEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:autofillHints="emailAddress"
                    android:hint="@string/auth_hint_email"
                    android:imeOptions="actionNext"
                    android:importantForAutofill="yes"
                    android:inputType="textEmailAddress" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="18dp"
            android:orientation="vertical">

            <TextView
                style="@style/TextAppearance.Coolcook.Auth.Label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auth_password" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/registerPasswordLayout"
                style="@style/Widget.Coolcook.Auth.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:endIconMode="password_toggle">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/registerPassword"
                    style="@style/Widget.Coolcook.Auth.TextInputEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:autofillHints="password"
                    android:hint="@string/auth_hint_password"
                    android:imeOptions="actionNext"
                    android:importantForAutofill="yes"
                    android:inputType="textPassword" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                style="@style/TextAppearance.Coolcook.Auth.Label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auth_confirm_password" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/registerConfirmPasswordLayout"
                style="@style/Widget.Coolcook.Auth.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:endIconMode="password_toggle">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/registerConfirmPassword"
                    style="@style/Widget.Coolcook.Auth.TextInputEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:autofillHints="password"
                    android:hint="@string/auth_hint_confirm_password"
                    android:imeOptions="actionDone"
                    android:importantForAutofill="yes"
                    android:inputType="textPassword" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>
    </LinearLayout>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnSubmitRegister"
        style="@style/Widget.Coolcook.Auth.PrimaryButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="28dp"
        android:text="@string/auth_register_title" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="20dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:alpha="0.4"
            android:background="@color/outline_variant" />

        <TextView
            style="@style/TextAppearance.Coolcook.Auth.DividerLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:text="@string/auth_or_connect" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:alpha="0.4"
            android:background="@color/outline_variant" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnGoogleRegister"
            style="@style/Widget.Coolcook.Auth.SocialCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/fg_ripple_rounded_medium"
            android:outlineProvider="background">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:minHeight="52dp"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingTop="12dp"
                android:paddingEnd="16dp"
                android:paddingBottom="12dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_google" />

                <TextView
                    style="@style/TextAppearance.Coolcook.Auth.SocialLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="@string/auth_google" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <Space
            android:layout_width="12dp"
            android:layout_height="1dp" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnFacebookRegister"
            style="@style/Widget.Coolcook.Auth.SocialCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/fg_ripple_rounded_medium"
            android:outlineProvider="background">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:minHeight="52dp"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingTop="12dp"
                android:paddingEnd="16dp"
                android:paddingBottom="12dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_facebook" />

                <TextView
                    style="@style/TextAppearance.Coolcook.Auth.SocialLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="@string/auth_facebook" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            style="@style/TextAppearance.Coolcook.Brand.Subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auth_has_account"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/txtSwitchToLogin"
            style="@style/TextAppearance.Coolcook.Auth.Link"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="@string/auth_login_now" />
    </LinearLayout>
</LinearLayout>
