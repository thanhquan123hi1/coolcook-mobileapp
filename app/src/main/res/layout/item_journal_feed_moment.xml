<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="22dp"
    android:orientation="vertical">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:stateListAnimator="@null"
        app:cardBackgroundColor="#FF0F0F10"
        app:cardCornerRadius="38dp"
        app:cardElevation="0dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/imgFeedMoment"
                android:layout_width="match_parent"
                android:layout_height="460dp"
                android:adjustViewBounds="false"
                android:contentDescription="@string/journal_photo_desc"
                android:scaleType="centerCrop"
                android:src="@drawable/img_scan_food_salad" />

            <View
                android:layout_width="match_parent"
                android:layout_height="128dp"
                android:layout_gravity="bottom"
                android:background="@drawable/bg_locket_caption_scrim" />

            <TextView
                android:id="@+id/txtFeedCaption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:layout_marginStart="22dp"
                android:layout_marginEnd="22dp"
                android:layout_marginBottom="20dp"
                android:fontFamily="@font/manrope"
                android:maxLines="2"
                android:textColor="#FFFFFFFF"
                android:textSize="17sp"
                android:textStyle="bold" />
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:stateListAnimator="@null"
            app:cardBackgroundColor="#FF2A2A2C"
            app:cardCornerRadius="999dp"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/imgFeedAvatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/journal_photo_desc"
                android:scaleType="centerCrop"
                android:src="@drawable/img_home_profile" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/txtFeedOwner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:fontFamily="@font/manrope"
            android:textColor="#FFFFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtFeedMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:fontFamily="@font/be_vietnam_pro"
            android:textColor="#99FFFFFF"
            android:textSize="15sp" />
    </LinearLayout>

</LinearLayout>
