<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FFF8F1"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="20dp"
    android:paddingEnd="20dp"
    android:paddingBottom="28dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="#D8C7B7" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/txtSuggestionDialogTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/be_vietnam_pro_bold"
            android:text="AI gợi ý món từ thực phẩm của bạn"
            android:textColor="#26180F"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/btnSuggestionDialogClose"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_food_icon_circle_light"
            android:fontFamily="@font/material_symbols_outlined"
            android:gravity="center"
            android:text="close"
            android:textColor="#3B2B20"
            android:textSize="22sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/txtSuggestionIngredientsLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/be_vietnam_pro_medium"
        android:text="Nguyên liệu đã nhận diện"
        android:textColor="#6A5341"
        android:textSize="13sp" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/groupSuggestionIngredients"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        app:chipSpacingHorizontal="8dp"
        app:chipSpacingVertical="8dp"
        app:singleLine="false" />

    <TextView
        android:id="@+id/txtSuggestionEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:fontFamily="@font/be_vietnam_pro"
        android:text="Chưa có món gợi ý phù hợp."
        android:textColor="#886A5341"
        android:textSize="13sp"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSuggestionDishes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:nestedScrollingEnabled="false" />
</LinearLayout>
