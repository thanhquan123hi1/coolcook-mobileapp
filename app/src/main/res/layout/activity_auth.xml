<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/authRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:clipChildren="false"
    android:clipToPadding="false">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideCardTop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.26" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideImageBottom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.55" />

    <FrameLayout
        android:id="@+id/topImageSection"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/guideImageBottom"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/imgAuthBackground"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/auth_background_desc"
            android:scaleType="centerCrop"
            android:src="@drawable/img_auth_background" />

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_auth_image_overlay" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/authHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="start"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingTop="12dp"
        android:paddingEnd="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_auth_back_button"
            android:contentDescription="@string/auth_back"
            android:padding="8dp"
            android:src="@drawable/ic_arrow_back_24"
            app:tint="@color/primary" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/authCard"
        style="@style/Widget.Coolcook.Auth.SheetCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:outlineProvider="background"
        app:cardBackgroundColor="@color/surface_container_lowest"
        app:cardUseCompatPadding="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/guideCardTop"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.Coolcook.AuthCard">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/authScroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:overScrollMode="never"
            android:scrollbars="none">

            <FrameLayout
                android:id="@+id/authContentContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="28dp"
                android:paddingTop="30dp"
                android:paddingEnd="28dp"
                android:paddingBottom="24dp">

                <LinearLayout
                    android:id="@+id/loginPanel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        style="@style/TextAppearance.Coolcook.Brand.Title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/auth_login_title"
                        android:textColor="@color/primary" />

                    <TextView
                        style="@style/TextAppearance.Coolcook.Brand.Subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="28dp"
                        android:text="@string/auth_login_subtitle" />

                    <LinearLayout
                        android:id="@+id/loginFields"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="18dp"
                            android:orientation="vertical">

                            <TextView
                                style="@style/TextAppearance.Coolcook.Auth.Label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/auth_email" />

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/loginEmailLayout"
                                style="@style/Widget.Coolcook.Auth.TextInputLayout"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/loginEmail"
                                    style="@style/Widget.Coolcook.Auth.TextInputEditText"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:autofillHints="emailAddress"
                                    android:hint="@string/auth_hint_email"
                                    android:imeOptions="actionNext"
                                    android:importantForAutofill="yes"
                                    android:inputType="textEmailAddress" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                style="@style/TextAppearance.Coolcook.Auth.Label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/auth_password" />

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/loginPasswordLayout"
                                style="@style/Widget.Coolcook.Auth.TextInputLayout"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                app:endIconMode="password_toggle">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/loginPassword"
                                    style="@style/Widget.Coolcook.Auth.TextInputEditText"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:autofillHints="password"
                                    android:hint="@string/auth_hint_password"
                                    android:imeOptions="actionDone"
                                    android:importantForAutofill="yes"
                                    android:inputType="textPassword" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <androidx.appcompat.widget.AppCompatCheckBox
                            android:id="@+id/chkRemember"
                            style="@style/Widget.Coolcook.Auth.Checkbox"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/auth_remember" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1" />

                        <TextView
                            style="@style/TextAppearance.Coolcook.Auth.Link"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/auth_forgot" />
                    </LinearLayout>

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnSubmitLogin"
                        style="@style/Widget.Coolcook.Auth.PrimaryButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="28dp"
                        android:text="@string/auth_login_title" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="28dp"
                        android:layout_marginBottom="20dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1"
                            android:alpha="0.4"
                            android:background="@color/outline_variant" />

                        <TextView
                            style="@style/TextAppearance.Coolcook.Auth.DividerLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_marginEnd="12dp"
                            android:text="@string/auth_or_connect" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1"
                            android:alpha="0.4"
                            android:background="@color/outline_variant" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnGoogleLogin"
                            style="@style/Widget.Coolcook.Auth.SocialCard"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="@drawable/fg_ripple_rounded_medium"
                            android:outlineProvider="background">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:minHeight="52dp"
                                android:orientation="horizontal"
                                android:paddingStart="16dp"
                                android:paddingTop="12dp"
                                android:paddingEnd="16dp"
                                android:paddingBottom="12dp">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:contentDescription="@null"
                                    android:src="@drawable/ic_google" />

                                <TextView
                                    style="@style/TextAppearance.Coolcook.Auth.SocialLabel"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="10dp"
                                    android:text="@string/auth_google" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <Space
                            android:layout_width="12dp"
                            android:layout_height="1dp" />

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnFacebookLogin"
                            style="@style/Widget.Coolcook.Auth.SocialCard"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="@drawable/fg_ripple_rounded_medium"
                            android:outlineProvider="background">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:minHeight="52dp"
                                android:orientation="horizontal"
                                android:paddingStart="16dp"
                                android:paddingTop="12dp"
                                android:paddingEnd="16dp"
                                android:paddingBottom="12dp">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:contentDescription="@null"
                                    android:src="@drawable/ic_facebook" />

                                <TextView
                                    style="@style/TextAppearance.Coolcook.Auth.SocialLabel"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="10dp"
                                    android:text="@string/auth_facebook" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="24dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <TextView
                            style="@style/TextAppearance.Coolcook.Brand.Subtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/auth_no_account"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/txtSwitchToRegister"
                            style="@style/TextAppearance.Coolcook.Auth.Link"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="@string/auth_register_now" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/registerPanel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        style="@style/TextAppearance.Coolcook.Brand.Title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/auth_register_title"
                        android:textColor="@color/primary" />

                    <TextView
                        style="@style/TextAppearance.Coolcook.Brand.Subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="28dp"
                        android:text="@string/auth_register_subtitle" />

                    <LinearLayout
                        android:id="@+id/registerFields"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="18dp"
                            android:orientation="vertical">

                            <TextView
                                style="@style/TextAppearance.Coolcook.Auth.Label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/auth_full_name" />

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/registerNameLayout"
                                style="@style/Widget.Coolcook.Auth.TextInputLayout"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/registerName"
                                    style="@style/Widget.Coolcook.Auth.TextInputEditText"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:autofillHints="name"
                                    android:hint="@string/auth_hint_full_name"
                                    android:imeOptions="actionNext"
                                    android:importantForAutofill="yes"
                                    android:inputType="textPersonName|textCapWords" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="18dp"
                            android:orientation="vertical">

                            <TextView
                                style="@style/TextAppearance.Coolcook.Auth.Label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/auth_email" />

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/registerEmailLayout"
                                style="@style/Widget.Coolcook.Auth.TextInputLayout"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/registerEmail"
                                    style="@style/Widget.Coolcook.Auth.TextInputEditText"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:autofillHints="emailAddress"
                                    android:hint="@string/auth_hint_email"
                                    android:imeOptions="actionNext"
                                    android:importantForAutofill="yes"
                                    android:inputType="textEmailAddress" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="18dp"
                            android:orientation="vertical">

                            <TextView
                                style="@style/TextAppearance.Coolcook.Auth.Label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/auth_password" />

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/registerPasswordLayout"
                                style="@style/Widget.Coolcook.Auth.TextInputLayout"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                app:endIconMode="password_toggle">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/registerPassword"
                                    style="@style/Widget.Coolcook.Auth.TextInputEditText"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:autofillHints="password"
                                    android:hint="@string/auth_hint_password"
                                    android:imeOptions="actionNext"
                                    android:importantForAutofill="yes"
                                    android:inputType="textPassword" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                style="@style/TextAppearance.Coolcook.Auth.Label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/auth_confirm_password" />

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/registerConfirmPasswordLayout"
                                style="@style/Widget.Coolcook.Auth.TextInputLayout"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                app:endIconMode="password_toggle">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/registerConfirmPassword"
                                    style="@style/Widget.Coolcook.Auth.TextInputEditText"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:autofillHints="password"
                                    android:hint="@string/auth_hint_confirm_password"
                                    android:imeOptions="actionDone"
                                    android:importantForAutofill="yes"
                                    android:inputType="textPassword" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnSubmitRegister"
                        style="@style/Widget.Coolcook.Auth.PrimaryButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="28dp"
                        android:text="@string/auth_register_title" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:layout_marginBottom="20dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1"
                            android:alpha="0.4"
                            android:background="@color/outline_variant" />

                        <TextView
                            style="@style/TextAppearance.Coolcook.Auth.DividerLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_marginEnd="12dp"
                            android:text="@string/auth_or_connect" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1"
                            android:alpha="0.4"
                            android:background="@color/outline_variant" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnGoogleRegister"
                            style="@style/Widget.Coolcook.Auth.SocialCard"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="@drawable/fg_ripple_rounded_medium"
                            android:outlineProvider="background">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:minHeight="52dp"
                                android:orientation="horizontal"
                                android:paddingStart="16dp"
                                android:paddingTop="12dp"
                                android:paddingEnd="16dp"
                                android:paddingBottom="12dp">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:contentDescription="@null"
                                    android:src="@drawable/ic_google" />

                                <TextView
                                    style="@style/TextAppearance.Coolcook.Auth.SocialLabel"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="10dp"
                                    android:text="@string/auth_google" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <Space
                            android:layout_width="12dp"
                            android:layout_height="1dp" />

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnFacebookRegister"
                            style="@style/Widget.Coolcook.Auth.SocialCard"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="@drawable/fg_ripple_rounded_medium"
                            android:outlineProvider="background">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:minHeight="52dp"
                                android:orientation="horizontal"
                                android:paddingStart="16dp"
                                android:paddingTop="12dp"
                                android:paddingEnd="16dp"
                                android:paddingBottom="12dp">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:contentDescription="@null"
                                    android:src="@drawable/ic_facebook" />

                                <TextView
                                    style="@style/TextAppearance.Coolcook.Auth.SocialLabel"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="10dp"
                                    android:text="@string/auth_facebook" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="24dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <TextView
                            style="@style/TextAppearance.Coolcook.Brand.Subtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/auth_has_account"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/txtSwitchToLogin"
                            style="@style/TextAppearance.Coolcook.Auth.Link"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="@string/auth_login_now" />
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>
        </androidx.core.widget.NestedScrollView>
    </com.google.android.material.card.MaterialCardView>

    <FrameLayout
        android:id="@+id/authLoadingOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#66000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ProgressBar
            android:id="@+id/authProgressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:contentDescription="@string/auth_loading" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
