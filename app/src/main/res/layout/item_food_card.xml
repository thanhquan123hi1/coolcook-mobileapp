<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.Coolcook.Home.SurfaceCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="6dp"
    android:layout_marginTop="8dp"
    android:layout_marginEnd="6dp"
    android:layout_marginBottom="10dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="@drawable/fg_ripple_rounded_large"
    app:cardBackgroundColor="@color/surface_container_lowest"
    app:cardCornerRadius="24dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/home_card_border_soft"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="132dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgFoodCard"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Coolcook.HomeRecipeImage"
                tools:src="@drawable/img_home_recipe_pho" />

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/txtFoodFavorite"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_food_icon_circle_light"
                android:clickable="true"
                android:contentDescription="Yeu thich"
                android:focusable="true"
                android:padding="7dp"
                android:scaleType="centerInside"
                app:srcCompat="@drawable/ic_favorite_outline"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/txtFoodCookTime"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:layout_gravity="bottom|end"
                android:layout_marginEnd="10dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_food_time_badge"
                android:fontFamily="@font/be_vietnam_pro_bold"
                android:gravity="center"
                android:includeFontPadding="false"
                android:minWidth="64dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:textColor="@color/on_surface"
                android:textSize="11sp"
                tools:text="45 MIN" />
        </FrameLayout>

        <TextView
            android:id="@+id/txtFoodName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="12dp"
            android:ellipsize="end"
            android:fontFamily="@font/be_vietnam_pro_bold"
            android:maxLines="2"
            android:textColor="@color/on_surface"
            android:textSize="15sp"
            tools:text="Cơm tấm sườn nướng" />

        <TextView
            android:id="@+id/txtFoodPrimaryTag"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:layout_marginStart="12dp"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_food_suitable_tag"
            android:ellipsize="end"
            android:fontFamily="@font/be_vietnam_pro_medium"
            android:gravity="center"
            android:maxLines="1"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:textColor="@color/on_surface_variant"
            android:textSize="11sp"
            tools:text="tăng cơ bắp" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
