<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/foodCatalogRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".ui.search.FoodCatalogActivity">

    <LinearLayout
        android:id="@+id/foodCatalogContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="30dp"
        android:paddingEnd="18dp"
        android:paddingBottom="18dp"
        app:layout_constraintBottom_toTopOf="@+id/homeBottomNav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/be_vietnam_pro_bold"
            android:includeFontPadding="false"
            android:text="Gợi ý món ngon"
            android:textColor="@color/primary"
            android:textSize="31sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_food_search_input"
            android:elevation="1dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingEnd="18dp">

            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:fontFamily="@font/material_symbols_outlined"
                android:fontVariationSettings="'wght' 600"
                android:gravity="center"
                android:text="search"
                android:textColor="@color/home_accent"
                android:textSize="22sp" />

            <EditText
                android:id="@+id/edtFoodSearch"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@null"
                android:fontFamily="@font/be_vietnam_pro"
                android:hint="Tìm món hoặc mục tiêu sức khỏe"
                android:imeOptions="actionSearch"
                android:includeFontPadding="false"
                android:inputType="text"
                android:maxLines="1"
                android:textColor="@color/on_surface"
                android:textColorHint="@color/home_search_placeholder"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/chipFoodAll"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:background="@drawable/bg_food_filter_chip_selected"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="@font/be_vietnam_pro_bold"
                android:gravity="center"
                android:minWidth="76dp"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="Tất cả"
                android:textColor="@color/on_primary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/chipFoodDry"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_food_filter_chip_unselected"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="@font/be_vietnam_pro_bold"
                android:gravity="center"
                android:minWidth="88dp"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="Món khô"
                android:textColor="@color/on_surface_variant"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/chipFoodSoup"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_food_filter_chip_unselected"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="@font/be_vietnam_pro_bold"
                android:gravity="center"
                android:minWidth="98dp"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="Món nước"
                android:textColor="@color/on_surface_variant"
                android:textSize="13sp" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="14dp"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerFoods"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:paddingBottom="12dp"
                tools:itemCount="6"
                tools:listitem="@layout/item_food_card" />

            <TextView
                android:id="@+id/txtFoodEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/be_vietnam_pro_medium"
                android:gravity="center"
                android:padding="24dp"
                android:text="Chưa tìm thấy món phù hợp"
                android:textColor="@color/on_surface_variant"
                android:textSize="15sp"
                android:visibility="gone" />
        </FrameLayout>
    </LinearLayout>

    <include
        android:id="@+id/homeBottomNav"
        layout="@layout/view_home_bottom_nav"
        android:layout_width="0dp"
        android:layout_height="@dimen/home_bottom_nav_height"
        android:layout_marginStart="@dimen/home_bottom_nav_margin_horizontal"
        android:layout_marginEnd="@dimen/home_bottom_nav_margin_horizontal"
        android:layout_marginBottom="@dimen/home_bottom_nav_margin_bottom"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintWidth_max="448dp"
        app:layout_constraintWidth_percent="0.9" />
</androidx.constraintlayout.widget.ConstraintLayout>
