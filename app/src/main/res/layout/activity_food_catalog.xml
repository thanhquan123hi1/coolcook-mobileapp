<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/foodCatalogRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_food_catalog_screen"
    android:clipChildren="false"
    android:clipToPadding="false"
    tools:context=".feature.search.ui.FoodCatalogActivity">

    <LinearLayout
        android:id="@+id/foodCatalogContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipChildren="true"
        android:clipToPadding="true"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="30dp"
        android:paddingEnd="18dp"
        android:paddingBottom="18dp"
        app:layout_constraintBottom_toTopOf="@+id/homeBottomNav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/txtFoodCatalogTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/manrope"
            android:includeFontPadding="false"
            android:text="Gợi ý món ngon"
            android:textColor="@color/home_text_primary"
            android:textSize="31sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/layoutFoodSearchBar"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_food_search_input_pastel"
            android:elevation="1dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingEnd="18dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_home_search_figma" />

            <EditText
                android:id="@+id/edtFoodSearch"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@null"
                android:fontFamily="@font/manrope"
                android:hint="Tìm món hoặc mục tiêu sức khỏe"
                android:imeOptions="actionSearch"
                android:includeFontPadding="false"
                android:inputType="text"
                android:maxLines="1"
                android:textColor="@color/home_text_primary"
                android:textColorHint="@color/home_search_placeholder"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/chipFoodAll"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:background="@drawable/bg_food_filter_chip_selected_pastel"
                android:clickable="true"
                android:drawableStart="@drawable/ic_food_chip_star"
                android:drawablePadding="8dp"
                android:focusable="true"
                android:fontFamily="@font/manrope"
                android:gravity="center"
                android:minWidth="76dp"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="Tất cả"
                android:textColor="@color/home_link_pink"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/chipFoodDry"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_food_filter_chip_unselected_pastel"
                android:clickable="true"
                android:drawableStart="@drawable/ic_food_chip_drumstick"
                android:drawablePadding="8dp"
                android:focusable="true"
                android:fontFamily="@font/manrope"
                android:gravity="center"
                android:minWidth="88dp"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="Món khô"
                android:textColor="@color/home_text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/chipFoodSoup"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_food_filter_chip_unselected_pastel"
                android:clickable="true"
                android:drawableStart="@drawable/ic_food_chip_bowl"
                android:drawablePadding="8dp"
                android:focusable="true"
                android:fontFamily="@font/manrope"
                android:gravity="center"
                android:minWidth="98dp"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="Món nước"
                android:textColor="@color/home_text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/chipFoodLowFat"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:background="@drawable/bg_food_filter_chip_unselected_pastel"
                android:clickable="true"
                android:drawableStart="@drawable/ic_food_chip_drop"
                android:drawablePadding="8dp"
                android:ellipsize="end"
                android:focusable="true"
                android:fontFamily="@font/manrope"
                android:gravity="center"
                android:maxLines="1"
                android:minWidth="104dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="Ít dầu mỡ"
                android:textColor="@color/home_text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/chipFoodStomach"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_food_filter_chip_unselected_pastel"
                android:clickable="true"
                android:drawableStart="@drawable/ic_food_chip_leaf"
                android:drawablePadding="8dp"
                android:ellipsize="end"
                android:focusable="true"
                android:fontFamily="@font/manrope"
                android:gravity="center"
                android:maxLines="1"
                android:minWidth="118dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="Tốt cho dạ dày"
                android:textColor="@color/home_text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/chipFoodProtein"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_food_filter_chip_unselected_pastel"
                android:clickable="true"
                android:drawableStart="@drawable/ic_food_chip_arm"
                android:drawablePadding="8dp"
                android:ellipsize="end"
                android:focusable="true"
                android:fontFamily="@font/manrope"
                android:gravity="center"
                android:maxLines="1"
                android:minWidth="108dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="Giàu protein"
                android:textColor="@color/home_text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="14dp"
            android:layout_weight="1"
            android:clipChildren="true"
            android:clipToPadding="true">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerFoods"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="true"
                android:overScrollMode="never"
                android:paddingBottom="12dp"
                tools:itemCount="6"
                tools:listitem="@layout/item_food_card" />

            <TextView
                android:id="@+id/txtFoodEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/manrope"
                android:gravity="center"
                android:padding="24dp"
                android:text="Chưa tìm thấy món phù hợp"
                android:textColor="@color/home_text_secondary"
                android:textSize="15sp"
                android:visibility="gone" />
        </FrameLayout>
    </LinearLayout>

    <ImageView
        android:layout_width="14dp"
        android:layout_height="14dp"
        android:layout_marginStart="32dp"
        android:layout_marginTop="52dp"
        android:contentDescription="@null"
        android:src="@drawable/ic_home_decor_sparkle_gold_figma"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_marginStart="22dp"
        android:layout_marginTop="112dp"
        android:contentDescription="@null"
        android:src="@drawable/ic_home_decor_flower_figma"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:layout_width="14dp"
        android:layout_height="14dp"
        android:layout_marginEnd="238dp"
        android:layout_marginTop="56dp"
        android:contentDescription="@null"
        android:src="@drawable/ic_home_decor_sparkle_gold_figma"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <FrameLayout
        android:layout_width="78dp"
        android:layout_height="78dp"
        android:layout_marginTop="46dp"
        android:layout_marginEnd="20dp"
        android:background="@drawable/bg_food_filter_chip_selected_pastel"
        android:elevation="2dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_gravity="center"
            android:contentDescription="@null"
            android:src="@drawable/ic_food_header_chef" />

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_gravity="bottom|start"
            android:layout_marginStart="-5dp"
            android:layout_marginBottom="10dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_home_decor_bunny_figma" />

        <ImageView
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="-4dp"
            android:layout_marginEnd="-2dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_home_decor_heart_figma" />
    </FrameLayout>

    <ImageView
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_marginTop="164dp"
        android:layout_marginEnd="30dp"
        android:contentDescription="@null"
        android:src="@drawable/ic_home_decor_bow_figma"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_marginStart="30dp"
        android:layout_marginTop="178dp"
        android:contentDescription="@null"
        android:src="@drawable/ic_home_decor_flower_figma"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <include
        android:id="@+id/homeBottomNav"
        layout="@layout/view_home_bottom_nav"
        android:layout_width="0dp"
        android:layout_height="@dimen/home_bottom_nav_height"
        android:layout_marginStart="@dimen/home_bottom_nav_margin_horizontal"
        android:layout_marginEnd="@dimen/home_bottom_nav_margin_horizontal"
        android:layout_marginBottom="@dimen/home_bottom_nav_margin_bottom"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintWidth_max="448dp"
        app:layout_constraintWidth_percent="0.9" />
</androidx.constraintlayout.widget.ConstraintLayout>
