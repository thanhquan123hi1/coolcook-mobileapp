<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/chatbotDrawer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.chatbot.ChatBotActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/chatbotRoot"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/chatbot_background"
        android:clipChildren="false"
        android:clipToPadding="false">

    <LinearLayout
        android:id="@+id/chatbotHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/chatbot_header_horizontal_padding"
        android:paddingTop="@dimen/chatbot_header_top_padding"
        android:paddingEnd="@dimen/chatbot_header_horizontal_padding"
        android:translationZ="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnChatbotBack"
            style="@style/Widget.Coolcook.Chatbot.SoftShadowCard"
            android:layout_width="@dimen/chatbot_header_button_size"
            android:layout_height="@dimen/chatbot_header_button_size"
            android:clickable="true"
            android:contentDescription="@string/chatbot_back_desc"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="999dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/material_symbols_outlined"
                android:text="arrow_back"
                android:textColor="@color/chatbot_icon_tint"
                android:textSize="@dimen/chatbot_header_icon_size" />
        </com.google.android.material.card.MaterialCardView>

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnChatbotGrid"
            style="@style/Widget.Coolcook.Chatbot.SoftShadowCard"
            android:layout_width="@dimen/chatbot_header_button_size"
            android:layout_height="@dimen/chatbot_header_button_size"
            android:clickable="true"
            android:contentDescription="@string/chatbot_grid_desc"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="999dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/material_symbols_outlined"
                android:text="grid_view"
                android:textColor="@color/chatbot_icon_tint"
                android:textSize="@dimen/chatbot_header_icon_size" />
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/chatbotIntro"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/chatbot_content_horizontal_padding"
        android:paddingTop="@dimen/chatbot_content_top_padding"
        android:paddingEnd="@dimen/chatbot_content_horizontal_padding"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/chatbotHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:orientation="horizontal"
            android:paddingEnd="8dp">

            <FrameLayout
                android:layout_width="@dimen/chatbot_hero_size"
                android:layout_height="@dimen/chatbot_hero_size"
                android:layout_margin="10dp"
                android:background="@drawable/bg_hero_card"
                android:paddingStart="@dimen/chatbot_hero_shadow_padding_horizontal"
                android:paddingTop="@dimen/chatbot_hero_shadow_padding_top"
                android:paddingEnd="@dimen/chatbot_hero_shadow_padding_horizontal"
                android:paddingBottom="@dimen/chatbot_hero_shadow_padding_bottom"
                android:rotation="8">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/chatbotHeroCard"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="@dimen/chatbot_hero_corner_radius"
                    app:cardElevation="0dp"
                    app:cardUseCompatPadding="false"
                    app:strokeColor="@color/white"
                    app:strokeWidth="@dimen/chatbot_hero_border_width">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/home_feature_image_desc"
                        android:scaleType="centerCrop"
                        android:src="@drawable/img_chatbot_hero_salmon"
                        tools:src="@drawable/img_chatbot_hero_salmon" />
                </com.google.android.material.card.MaterialCardView>
            </FrameLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/txtChatbotTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/chatbot_title_margin_top"
            android:fontFamily="@font/plus_jakarta_sans"
            android:lineSpacingExtra="1dp"
            android:text="@string/chatbot_title"
            android:textColor="@color/chatbot_title"
            android:textSize="@dimen/chatbot_title_text_size"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtChatbotSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/chatbot_subtitle_margin_top"
            android:fontFamily="@font/plus_jakarta_sans"
            android:lineSpacingExtra="1dp"
            android:text="@string/chatbot_subtitle"
            android:textColor="@color/chatbot_subtitle"
            android:textSize="@dimen/chatbot_subtitle_text_size" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/chatbot_chip_margin_top"
            android:overScrollMode="never"
            android:scrollbars="none">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipQuickPrompts"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                app:chipSpacingHorizontal="@dimen/chatbot_chip_spacing"
                app:singleSelection="false">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipPrompt1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/be_vietnam_pro_medium"
                    android:text="@string/chatbot_quick_prompt_1"
                    android:textColor="@color/chatbot_chip_text"
                    android:textSize="13sp"
                    app:chipBackgroundColor="@color/chatbot_chip_bg"
                    app:chipCornerRadius="16dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipPrompt2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/be_vietnam_pro_medium"
                    android:text="@string/chatbot_quick_prompt_2"
                    android:textColor="@color/chatbot_chip_text"
                    android:textSize="13sp"
                    app:chipBackgroundColor="@color/chatbot_chip_bg"
                    app:chipCornerRadius="16dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipPrompt3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/be_vietnam_pro_medium"
                    android:text="@string/chatbot_quick_prompt_3"
                    android:textColor="@color/chatbot_chip_text"
                    android:textSize="13sp"
                    app:chipBackgroundColor="@color/chatbot_chip_bg"
                    app:chipCornerRadius="16dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipPrompt4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/be_vietnam_pro_medium"
                    android:text="@string/chatbot_quick_prompt_4"
                    android:textColor="@color/chatbot_chip_text"
                    android:textSize="13sp"
                    app:chipBackgroundColor="@color/chatbot_chip_bg"
                    app:chipCornerRadius="16dp" />
            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChatMessages"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingStart="8dp"
        android:paddingTop="@dimen/chatbot_chat_list_margin_top"
        android:paddingEnd="8dp"
        android:paddingBottom="@dimen/chatbot_chat_list_padding_bottom"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/typingIndicatorGroup"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/chatbotIntro"
        tools:itemCount="3"
        tools:listitem="@layout/item_chat_message" />

    <LinearLayout
        android:id="@+id/typingIndicatorGroup"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="14dp"
        android:gravity="top|start"
        android:orientation="horizontal"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/chatbotInputCard"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:visibility="visible">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginTop="4dp"
            android:contentDescription="@string/chatbot_ai_avatar_desc"
            app:cardBackgroundColor="@color/chatbot_ai_avatar_bg"
            app:cardCornerRadius="999dp"
            app:cardElevation="0dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/material_symbols_outlined"
                android:text="smart_toy"
                android:textColor="@color/chatbot_ai_avatar_icon"
                android:textSize="16sp" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:fontFamily="@font/be_vietnam_pro_medium"
            android:text="@string/chatbot_typing"
            android:textColor="@color/chatbot_subtitle"
            android:textSize="13sp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/layoutTypingDots"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_chat_message_ai"
            android:paddingStart="16dp"
            android:paddingTop="10dp"
            android:paddingEnd="16dp"
            android:paddingBottom="10dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/dot1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/be_vietnam_pro_bold"
                android:text="•"
                android:textColor="@color/chatbot_typing_dot"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/dot2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="1dp"
                android:fontFamily="@font/be_vietnam_pro_bold"
                android:text="•"
                android:textColor="@color/chatbot_typing_dot"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/dot3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="1dp"
                android:fontFamily="@font/be_vietnam_pro_bold"
                android:text="•"
                android:textColor="@color/chatbot_typing_dot"
                android:textSize="18sp" />
        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/chatbotInputCard"
        style="@style/Widget.Coolcook.Chatbot.SoftShadowCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/chatbot_input_margin_horizontal"
        android:layout_marginEnd="@dimen/chatbot_input_margin_horizontal"
        android:layout_marginBottom="@dimen/chatbot_input_margin_bottom"
        app:cardBackgroundColor="@color/chatbot_input_card_bg"
        app:cardCornerRadius="@dimen/chatbot_input_corner_radius"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:strokeColor="@color/chatbot_input_border"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/chatbot_input_padding_horizontal"
            android:paddingTop="@dimen/chatbot_input_padding_top"
            android:paddingEnd="@dimen/chatbot_input_padding_horizontal"
            android:paddingBottom="@dimen/chatbot_input_padding_bottom">

            <TextView
                android:id="@+id/txtAttachedImage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:background="@drawable/bg_chatbot_bubble"
                android:fontFamily="@font/be_vietnam_pro_medium"
                android:paddingStart="10dp"
                android:paddingTop="6dp"
                android:paddingEnd="10dp"
                android:paddingBottom="6dp"
                android:text="@string/chatbot_image_attached"
                android:textColor="@color/chatbot_subtitle"
                android:textSize="12sp"
                android:visibility="gone"
                tools:visibility="visible" />

            <EditText
                android:id="@+id/edtChatbotPrompt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:fontFamily="@font/plus_jakarta_sans"
                android:gravity="top|start"
                android:hint="@string/chatbot_prompt_hint"
                android:importantForAutofill="no"
                android:inputType="textCapSentences|textMultiLine"
                android:lineSpacingExtra="2dp"
                android:maxLines="4"
                android:minHeight="72dp"
                android:minLines="2"
                android:paddingTop="@dimen/chatbot_prompt_hint_padding_top"
                android:paddingBottom="@dimen/chatbot_prompt_hint_padding_bottom"
                android:textColor="@color/chatbot_title"
                android:textColorHint="@color/chatbot_hint"
                android:textSize="16sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnChatbotUpload"
                    style="@style/Widget.Coolcook.Chatbot.SoftShadowCard"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/chatbot_upload_button_height"
                    android:clickable="true"
                    android:contentDescription="@string/chatbot_upload_desc"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    app:cardBackgroundColor="@color/chatbot_upload_bg"
                    app:cardCornerRadius="999dp"
                    app:strokeColor="@color/chatbot_button_stroke"
                    app:strokeWidth="1.5dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="@dimen/chatbot_upload_button_padding_horizontal"
                        android:paddingEnd="@dimen/chatbot_upload_button_padding_horizontal">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_chatbot_upload"
                            app:tint="@color/chatbot_upload_icon" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="9dp"
                            android:fontFamily="@font/plus_jakarta_sans"
                            android:text="@string/chatbot_upload"
                            android:textColor="@color/chatbot_upload_text"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <Space
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnChatbotSend"
                    style="@style/Widget.Coolcook.Chatbot.SoftShadowCard"
                    android:layout_width="@dimen/chatbot_send_button_size"
                    android:layout_height="@dimen/chatbot_send_button_size"
                    android:clickable="true"
                    android:contentDescription="@string/chatbot_send_desc"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    app:cardBackgroundColor="@color/chatbot_send_button_bg"
                    app:cardCornerRadius="999dp"
                    app:strokeColor="@android:color/transparent">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chatbot_send" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/chatbotHistoryPanel"
        android:layout_width="320dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="@drawable/bg_chatbot_history_panel"
        android:clipToOutline="true"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="20dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/plus_jakarta_sans"
                android:text="@string/chatbot_session_title"
                android:textColor="@color/chatbot_title"
                android:textSize="18sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNewChat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/be_vietnam_pro_bold"
                android:minHeight="40dp"
                android:text="@string/chatbot_new_chat"
                android:textAllCaps="false"
                android:textColor="@color/chatbot_title"
                app:backgroundTint="@color/chatbot_session_card_bg"
                app:cornerRadius="14dp"
                app:elevation="0dp"
                app:icon="@drawable/ic_chatbot_add"
                app:iconPadding="6dp"
                app:iconTint="@color/chatbot_title"
                app:strokeColor="@color/chatbot_session_card_border"
                app:strokeWidth="1dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtNoSessions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/be_vietnam_pro"
            android:text="@string/chatbot_no_sessions"
            android:textColor="@color/chatbot_subtitle"
            android:textSize="13sp"
            android:visibility="gone"
            tools:visibility="visible" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvChatSessions"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingBottom="8dp"
            tools:itemCount="4"
            tools:listitem="@layout/item_chat_session" />
    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>