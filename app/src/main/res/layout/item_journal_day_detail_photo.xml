<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="@dimen/journal_detail_photo_height"
    android:layout_margin="4dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="#1A000000"
    app:strokeWidth="1dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/imgJournalDayPhoto"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/journal_photo_desc"
            android:scaleType="centerCrop"
            android:src="@drawable/bg_journal_placeholder_cute" />

        <TextView
            android:id="@+id/txtJournalDayPlaceholder"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:fontFamily="@font/material_symbols_outlined"
            android:gravity="center"
            android:text="restaurant"
            android:textColor="@color/primary"
            android:textSize="24sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/txtJournalDayEntryBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_margin="10dp"
            android:background="@drawable/bg_food_time_badge"
            android:paddingStart="8dp"
            android:paddingTop="4dp"
            android:paddingEnd="8dp"
            android:paddingBottom="4dp"
            android:text="Mon an"
            android:textColor="@color/on_surface"
            android:textSize="11sp" />
    </FrameLayout>

</com.google.android.material.card.MaterialCardView>
