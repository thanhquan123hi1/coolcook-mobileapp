<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="@dimen/journal_detail_photo_height"
    android:layout_margin="4dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="#1A000000"
    app:strokeWidth="1dp">

    <ImageView
        android:id="@+id/imgJournalDayPhoto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:contentDescription="@string/journal_photo_desc"
        android:src="@drawable/bg_journal_placeholder_cute" />

</com.google.android.material.card.MaterialCardView>