<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/journalDayRoot"
    android:layout_width="match_parent"
    android:layout_height="@dimen/journal_day_cell_height"
    android:layout_marginBottom="@dimen/journal_day_cell_bottom_margin"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:paddingStart="@dimen/journal_day_cell_side_padding"
    android:paddingEnd="@dimen/journal_day_cell_side_padding">

    <FrameLayout
        android:id="@+id/journalDayPhotoSlot"
        android:layout_width="match_parent"
        android:layout_height="@dimen/journal_day_stack_height_default"
        android:layout_gravity="top|center_horizontal"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:paddingStart="2dp"
        android:paddingEnd="2dp">

        <FrameLayout
            android:id="@+id/journalDayPhotoCluster"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:clipChildren="false"
            android:clipToPadding="false">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardJournalPhotoBack"
                android:layout_width="@dimen/journal_day_photo_width"
                android:layout_height="@dimen/journal_day_photo_height"
                android:layout_gravity="top|center_horizontal"
                app:cardCornerRadius="@dimen/journal_day_photo_corner"
                app:cardElevation="@dimen/journal_day_photo_elevation"
                app:strokeColor="@android:color/white"
                app:strokeWidth="@dimen/journal_day_photo_stroke">

                <ImageView
                    android:id="@+id/imgJournalPhotoBack"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/journal_photo_desc"
                    android:scaleType="centerCrop"
                    android:src="@drawable/bg_journal_placeholder_cute" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardJournalPhotoFront"
                android:layout_width="@dimen/journal_day_photo_width"
                android:layout_height="@dimen/journal_day_photo_height"
                android:layout_gravity="top|center_horizontal"
                app:cardCornerRadius="@dimen/journal_day_photo_corner"
                app:cardElevation="@dimen/journal_day_photo_elevation"
                app:strokeColor="@android:color/white"
                app:strokeWidth="@dimen/journal_day_photo_stroke">

                <ImageView
                    android:id="@+id/imgJournalPhotoFront"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/journal_photo_desc"
                    android:scaleType="centerCrop"
                    android:src="@drawable/bg_journal_placeholder_cute" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/txtJournalDayBadge"
                android:layout_width="@dimen/journal_day_badge_width"
                android:layout_height="@dimen/journal_day_badge_height"
                android:layout_gravity="bottom|center_horizontal"
                android:background="@drawable/bg_journal_extra_badge"
                android:elevation="0dp"
                android:fontFamily="@font/be_vietnam_pro_bold"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="+3"
                android:textColor="@color/on_surface"
                android:textSize="@dimen/journal_day_badge_text_size"
                android:visibility="gone" />
        </FrameLayout>
    </FrameLayout>

    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="@dimen/journal_day_number_margin_bottom">

        <TextView
            android:id="@+id/txtJournalDayNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/be_vietnam_pro_medium"
            android:text="1"
            android:textColor="@color/on_surface_variant"
            android:textSize="@dimen/journal_day_number_text_size" />

        <View
            android:id="@+id/viewJournalDayEntryDot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="-8dp"
            android:background="@drawable/bg_journal_day_entry_dot"
            android:visibility="gone" />
    </FrameLayout>

</FrameLayout>
