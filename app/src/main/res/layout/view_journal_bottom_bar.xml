<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/journalFooterContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="@dimen/journal_outer_padding"
    android:paddingTop="0dp"
    android:paddingEnd="@dimen/journal_outer_padding"
    android:paddingBottom="@dimen/journal_bottom_bar_padding_bottom">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/btnJournalGallery"
        android:layout_width="@dimen/journal_bottom_icon_size"
        android:layout_height="@dimen/journal_bottom_icon_size"
        android:clickable="true"
        android:focusable="true"
        android:foreground="@drawable/fg_ripple_circle"
        android:stateListAnimator="@null"
        app:cardBackgroundColor="@color/journal_surface_pill"
        app:cardCornerRadius="999dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="@id/btnJournalShutter"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnJournalShutter">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:fontFamily="@font/material_symbols_outlined"
            android:text="photo_library"
            android:textColor="@color/journal_text_primary"
            android:textSize="@dimen/journal_bottom_icon_glyph_size" />
    </com.google.android.material.card.MaterialCardView>

    <include
        layout="@layout/view_journal_shutter_button"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/btnJournalFlipCamera"
        android:layout_width="@dimen/journal_bottom_icon_size"
        android:layout_height="@dimen/journal_bottom_icon_size"
        android:clickable="true"
        android:focusable="true"
        android:foreground="@drawable/fg_ripple_circle"
        android:stateListAnimator="@null"
        app:cardBackgroundColor="@color/journal_surface_pill"
        app:cardCornerRadius="999dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="@id/btnJournalShutter"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnJournalShutter">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:fontFamily="@font/material_symbols_outlined"
            android:text="flip_camera_ios"
            android:textColor="@color/journal_text_primary"
            android:textSize="@dimen/journal_bottom_icon_glyph_size" />
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/txtJournalModeLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone" />

</androidx.constraintlayout.widget.ConstraintLayout>
