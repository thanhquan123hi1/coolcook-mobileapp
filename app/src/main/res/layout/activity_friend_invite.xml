<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/friendInviteRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF000000">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/inviteCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="24dp"
        android:stateListAnimator="@null"
        app:cardBackgroundColor="#FFFFFCF5"
        app:cardCornerRadius="34dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:strokeColor="#24FFFFFF"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="28dp"
            android:paddingEnd="24dp"
            android:paddingBottom="24dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:stateListAnimator="@null"
                app:cardBackgroundColor="#FFFFE3A3"
                app:cardCornerRadius="999dp"
                app:cardElevation="0dp">

                <ImageView
                    android:id="@+id/imgInviteAvatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/journal_photo_desc"
                    android:scaleType="centerCrop"
                    android:src="@drawable/img_home_profile" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/txtInviteTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/manrope"
                android:text="Lời mời kết bạn"
                android:textColor="#FF2B2118"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtInviteSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/be_vietnam_pro"
                android:gravity="center"
                android:text="Đang tải thông tin lời mời..."
                android:textColor="#FF7B6048"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/txtInviteStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/be_vietnam_pro_medium"
                android:gravity="center"
                android:textColor="#FFE29A16"
                android:textSize="14sp" />

            <ProgressBar
                android:id="@+id/inviteLoading"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginTop="18dp" />

            <TextView
                android:id="@+id/btnAcceptInvite"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:background="@drawable/bg_locket_primary_button"
                android:fontFamily="@font/manrope"
                android:gravity="center"
                android:minHeight="56dp"
                android:paddingStart="20dp"
                android:paddingTop="14dp"
                android:paddingEnd="20dp"
                android:paddingBottom="14dp"
                android:text="Chấp nhận"
                android:textColor="#FF111111"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnRejectInvite"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_locket_secondary_light_button"
                android:fontFamily="@font/manrope"
                android:gravity="center"
                android:minHeight="56dp"
                android:paddingStart="20dp"
                android:paddingTop="14dp"
                android:paddingEnd="20dp"
                android:paddingBottom="14dp"
                android:text="Từ chối"
                android:textColor="#FF5F4937"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnInviteClose"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/manrope"
                android:gravity="center"
                android:minHeight="48dp"
                android:paddingStart="20dp"
                android:paddingTop="12dp"
                android:paddingEnd="20dp"
                android:paddingBottom="12dp"
                android:text="Đóng"
                android:textColor="#FF9A7A5F"
                android:textSize="17sp"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
