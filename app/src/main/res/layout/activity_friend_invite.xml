<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/friendInviteRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF000000">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/inviteCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="22dp"
        android:layout_marginEnd="22dp"
        android:stateListAnimator="@null"
        app:cardBackgroundColor="#FFFFD84D"
        app:cardCornerRadius="36dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="30dp"
            android:paddingEnd="24dp"
            android:paddingBottom="26dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="92dp"
                android:layout_height="92dp"
                android:stateListAnimator="@null"
                app:cardBackgroundColor="#FFFFFFFF"
                app:cardCornerRadius="999dp"
                app:cardElevation="0dp"
                app:strokeColor="#FF111111"
                app:strokeWidth="3dp">

                <ImageView
                    android:id="@+id/imgInviteAvatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/journal_photo_desc"
                    android:scaleType="centerCrop"
                    android:src="@drawable/img_home_profile" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/txtInviteTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:fontFamily="@font/manrope"
                android:gravity="center"
                android:text="Kết bạn trên CoolCook"
                android:textColor="#FF111111"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtInviteSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/be_vietnam_pro_medium"
                android:gravity="center"
                android:lineSpacingExtra="3dp"
                android:text="Mã này là nhận diện cố định của bạn trên CoolCook."
                android:textColor="#CC111111"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtInviteStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/be_vietnam_pro_medium"
                android:gravity="center"
                android:textColor="#FF5F4937"
                android:textSize="14sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/inviteLoading"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginTop="18dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/txtFriendInviteCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:background="@drawable/bg_locket_input"
                android:fontFamily="@font/manrope"
                android:gravity="center"
                android:letterSpacing="0.08"
                android:minHeight="58dp"
                android:paddingStart="18dp"
                android:paddingTop="14dp"
                android:paddingEnd="18dp"
                android:paddingBottom="14dp"
                android:text="--------"
                android:textColor="#FFFFFFFF"
                android:textSize="23sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnCreateInviteCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_locket_primary_button"
                android:fontFamily="@font/manrope"
                android:gravity="center"
                android:minHeight="58dp"
                android:paddingStart="20dp"
                android:paddingTop="14dp"
                android:paddingEnd="20dp"
                android:paddingBottom="14dp"
                android:text="Sao chép mã"
                android:textColor="#FF111111"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnShareInviteCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_locket_secondary_button"
                android:fontFamily="@font/manrope"
                android:gravity="center"
                android:minHeight="58dp"
                android:paddingStart="20dp"
                android:paddingTop="14dp"
                android:paddingEnd="20dp"
                android:paddingBottom="14dp"
                android:text="Gửi lời mời kết bạn"
                android:textColor="#FFFFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtFriendInviteCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_locket_input"
                android:fontFamily="@font/manrope"
                android:gravity="center"
                android:hint="Nhập mã bạn bè"
                android:imeOptions="actionDone"
                android:inputType="textCapCharacters"
                android:maxLength="8"
                android:maxLines="1"
                android:minHeight="58dp"
                android:paddingStart="18dp"
                android:paddingTop="14dp"
                android:paddingEnd="18dp"
                android:paddingBottom="14dp"
                android:textColor="#FFFFFFFF"
                android:textColorHint="#B3FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnAcceptInvite"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_locket_secondary_button"
                android:fontFamily="@font/manrope"
                android:gravity="center"
                android:minHeight="58dp"
                android:paddingStart="20dp"
                android:paddingTop="14dp"
                android:paddingEnd="20dp"
                android:paddingBottom="14dp"
                android:text="Kết bạn"
                android:textColor="#FFFFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnInviteReject"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_locket_secondary_light_button"
                android:fontFamily="@font/manrope"
                android:gravity="center"
                android:minHeight="56dp"
                android:paddingStart="20dp"
                android:paddingTop="14dp"
                android:paddingEnd="20dp"
                android:paddingBottom="14dp"
                android:text="Từ chối"
                android:textColor="#FF5F4937"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnInviteClose"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/manrope"
                android:gravity="center"
                android:minHeight="48dp"
                android:paddingStart="20dp"
                android:paddingTop="12dp"
                android:paddingEnd="20dp"
                android:paddingBottom="12dp"
                android:text="Đóng"
                android:textColor="#AA111111"
                android:textSize="17sp"
                android:textStyle="bold" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>