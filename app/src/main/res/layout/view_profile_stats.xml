<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/profile_stats_card_margin_top"
    android:background="@drawable/bg_profile_stats_card"
    android:baselineAligned="false"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:elevation="10dp"
    android:gravity="center"
    android:orientation="horizontal"
    android:paddingStart="@dimen/profile_stats_card_padding_horizontal"
    android:paddingTop="@dimen/profile_stats_card_padding_vertical"
    android:paddingEnd="@dimen/profile_stats_card_padding_horizontal"
    android:paddingBottom="@dimen/profile_stats_card_padding_vertical"
    android:weightSum="3">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:background="@drawable/bg_profile_pastel_icon_circle"
                android:backgroundTint="@color/profile_icon_pink_bg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:fontFamily="@font/material_symbols_outlined"
                    android:fontVariationSettings="'wght' 400"
                    android:text="groups"
                    android:textColor="@color/profile_icon_pink_fg"
                    android:textSize="18sp" />
            </FrameLayout>

            <ImageView
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_marginStart="3dp"
                android:layout_marginBottom="10dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_home_decor_sparkle_pink_figma" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtStatFriends"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="@font/be_vietnam_pro"
            android:text="0"
            android:textColor="@color/primary"
            android:textSize="@dimen/profile_stats_value_text_size"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="@font/be_vietnam_pro"
            android:text="@string/profile_stats_cooked"
            android:textAllCaps="true"
            android:textColor="@color/home_text_primary"
            android:textSize="@dimen/profile_stats_label_text_size"
            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="6dp"
        android:background="@color/profile_divider_soft" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:background="@drawable/bg_profile_pastel_icon_circle"
            android:backgroundTint="@color/profile_icon_yellow_bg">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/material_symbols_outlined"
                android:fontVariationSettings="'wght' 400"
                android:text="bookmark"
                android:textColor="@color/profile_icon_yellow_fg"
                android:textSize="18sp" />
        </FrameLayout>

        <TextView
            android:id="@+id/txtStatSavedDishes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="@font/be_vietnam_pro"
            android:text="0"
            android:textColor="@color/primary"
            android:textSize="@dimen/profile_stats_value_text_size"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="@font/be_vietnam_pro"
            android:text="@string/profile_stats_saved"
            android:textAllCaps="true"
            android:textColor="@color/home_text_primary"
            android:textSize="@dimen/profile_stats_label_text_size"
            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="6dp"
        android:background="@color/profile_divider_soft" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:background="@drawable/bg_profile_pastel_icon_circle"
                android:backgroundTint="@color/profile_icon_purple_bg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:fontFamily="@font/material_symbols_outlined"
                    android:fontVariationSettings="'wght' 400"
                    android:text="photo_camera"
                    android:textColor="@color/profile_icon_purple_fg"
                    android:textSize="18sp" />
            </FrameLayout>

            <ImageView
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_marginStart="3dp"
                android:layout_marginBottom="10dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_home_decor_sparkle_gold_figma" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtStatPhotos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="@font/be_vietnam_pro"
            android:text="0"
            android:textColor="@color/primary"
            android:textSize="@dimen/profile_stats_value_text_size"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="@font/be_vietnam_pro"
            android:text="@string/profile_stats_posts"
            android:textAllCaps="true"
            android:textColor="@color/home_text_primary"
            android:textSize="@dimen/profile_stats_label_text_size"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
