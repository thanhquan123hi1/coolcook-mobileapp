<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/profile_section_title_margin_top"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/be_vietnam_pro_bold"
            android:text="@string/profile_section_activity"
            android:textColor="@color/home_text_primary"
            android:textSize="@dimen/profile_section_title_text_size"
            android:textStyle="bold" />

        <ImageView
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_marginStart="8dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_home_decor_heart_figma" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <ImageView
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_home_decor_teddy_figma" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/actionProfileSavedFoods"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/profile_action_item_margin_top"
        android:background="@drawable/bg_profile_action_item"
        android:elevation="10dp"
        android:gravity="center_vertical"
        android:minHeight="@dimen/profile_action_item_min_height"
        android:orientation="horizontal"
        android:paddingStart="@dimen/profile_action_item_padding_horizontal"
        android:paddingEnd="@dimen/profile_action_item_padding_horizontal">

        <FrameLayout
            android:layout_width="@dimen/profile_action_icon_container_size"
            android:layout_height="@dimen/profile_action_icon_container_size"
            android:background="@drawable/bg_profile_pastel_icon_circle"
            android:backgroundTint="@color/profile_icon_pink_bg">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/material_symbols_outlined"
                android:fontVariationSettings="'wght' 400"
                android:text="bookmark"
                android:textColor="@color/profile_icon_pink_fg"
                android:textSize="@dimen/profile_action_icon_size" />
        </FrameLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/profile_action_text_margin_start"
            android:layout_weight="1"
            android:fontFamily="@font/be_vietnam_pro"
            android:text="@string/profile_action_saved"
            android:textColor="@color/home_text_primary"
            android:textSize="@dimen/profile_action_text_size"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/material_symbols_outlined"
            android:fontVariationSettings="'wght' 300"
            android:text="chevron_right"
            android:textColor="@color/home_text_secondary"
            android:textSize="22sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/actionProfileJournal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/profile_action_item_margin_top"
        android:background="@drawable/bg_profile_action_item"
        android:elevation="10dp"
        android:gravity="center_vertical"
        android:minHeight="@dimen/profile_action_item_min_height"
        android:orientation="horizontal"
        android:paddingStart="@dimen/profile_action_item_padding_horizontal"
        android:paddingEnd="@dimen/profile_action_item_padding_horizontal">

        <FrameLayout
            android:layout_width="@dimen/profile_action_icon_container_size"
            android:layout_height="@dimen/profile_action_icon_container_size"
            android:background="@drawable/bg_profile_pastel_icon_circle"
            android:backgroundTint="@color/profile_icon_yellow_bg">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/material_symbols_outlined"
                android:fontVariationSettings="'wght' 400"
                android:text="auto_stories"
                android:textColor="@color/profile_icon_yellow_fg"
                android:textSize="@dimen/profile_action_icon_size" />
        </FrameLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/profile_action_text_margin_start"
            android:layout_weight="1"
            android:fontFamily="@font/be_vietnam_pro"
            android:text="@string/profile_action_journal"
            android:textColor="@color/home_text_primary"
            android:textSize="@dimen/profile_action_text_size"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/material_symbols_outlined"
            android:fontVariationSettings="'wght' 300"
            android:text="chevron_right"
            android:textColor="@color/home_text_secondary"
            android:textSize="22sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/actionProfileFavorites"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/profile_action_item_margin_top"
        android:background="@drawable/bg_profile_action_item"
        android:elevation="10dp"
        android:gravity="center_vertical"
        android:minHeight="@dimen/profile_action_item_min_height"
        android:orientation="horizontal"
        android:paddingStart="@dimen/profile_action_item_padding_horizontal"
        android:paddingEnd="@dimen/profile_action_item_padding_horizontal">

        <FrameLayout
            android:layout_width="@dimen/profile_action_icon_container_size"
            android:layout_height="@dimen/profile_action_icon_container_size"
            android:background="@drawable/bg_profile_pastel_icon_circle"
            android:backgroundTint="@color/profile_icon_pink_bg">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/material_symbols_outlined"
                android:fontVariationSettings="'wght' 350"
                android:text="favorite"
                android:textColor="@color/profile_icon_pink_fg"
                android:textSize="@dimen/profile_action_icon_size" />
        </FrameLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/profile_action_text_margin_start"
            android:layout_weight="1"
            android:fontFamily="@font/be_vietnam_pro"
            android:text="@string/profile_action_favorites"
            android:textColor="@color/home_text_primary"
            android:textSize="@dimen/profile_action_text_size"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/material_symbols_outlined"
            android:fontVariationSettings="'wght' 300"
            android:text="chevron_right"
            android:textColor="@color/home_text_secondary"
            android:textSize="22sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/actionProfileHealth"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/profile_action_item_margin_top"
        android:background="@drawable/bg_profile_action_item"
        android:elevation="10dp"
        android:gravity="center_vertical"
        android:minHeight="@dimen/profile_action_item_min_height"
        android:orientation="horizontal"
        android:paddingStart="@dimen/profile_action_item_padding_horizontal"
        android:paddingEnd="@dimen/profile_action_item_padding_horizontal">

        <FrameLayout
            android:layout_width="@dimen/profile_action_icon_container_size"
            android:layout_height="@dimen/profile_action_icon_container_size"
            android:background="@drawable/bg_profile_pastel_icon_circle"
            android:backgroundTint="@color/profile_icon_green_bg">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/material_symbols_outlined"
                android:fontVariationSettings="'wght' 400"
                android:text="monitor_heart"
                android:textColor="@color/profile_icon_green_fg"
                android:textSize="@dimen/profile_action_icon_size" />
        </FrameLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/profile_action_text_margin_start"
            android:layout_weight="1"
            android:fontFamily="@font/be_vietnam_pro"
            android:text="@string/profile_action_health"
            android:textColor="@color/home_text_primary"
            android:textSize="@dimen/profile_action_text_size"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/material_symbols_outlined"
            android:fontVariationSettings="'wght' 300"
            android:text="chevron_right"
            android:textColor="@color/home_text_secondary"
            android:textSize="22sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/actionProfileSettings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/profile_action_item_margin_top"
        android:background="@drawable/bg_profile_action_item"
        android:elevation="10dp"
        android:gravity="center_vertical"
        android:minHeight="@dimen/profile_action_item_min_height"
        android:orientation="horizontal"
        android:paddingStart="@dimen/profile_action_item_padding_horizontal"
        android:paddingEnd="@dimen/profile_action_item_padding_horizontal">

        <FrameLayout
            android:layout_width="@dimen/profile_action_icon_container_size"
            android:layout_height="@dimen/profile_action_icon_container_size"
            android:background="@drawable/bg_profile_pastel_icon_circle"
            android:backgroundTint="@color/profile_icon_purple_bg">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/material_symbols_outlined"
                android:fontVariationSettings="'wght' 400"
                android:text="settings"
                android:textColor="@color/profile_icon_purple_fg"
                android:textSize="@dimen/profile_action_icon_size" />
        </FrameLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/profile_action_text_margin_start"
            android:layout_weight="1"
            android:fontFamily="@font/be_vietnam_pro"
            android:text="@string/profile_action_settings"
            android:textColor="@color/home_text_primary"
            android:textSize="@dimen/profile_action_text_size"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/material_symbols_outlined"
            android:fontVariationSettings="'wght' 300"
            android:text="chevron_right"
            android:textColor="@color/home_text_secondary"
            android:textSize="22sp" />
    </LinearLayout>
</LinearLayout>
