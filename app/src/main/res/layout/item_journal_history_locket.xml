<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    android:paddingBottom="@dimen/journal_history_page_bottom_safe_padding">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/journalHistoryCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="@dimen/journal_history_page_card_horizontal_margin"
        android:layout_marginTop="@dimen/journal_history_page_card_top_margin"
        android:layout_marginEnd="@dimen/journal_history_page_card_horizontal_margin"
        android:background="@drawable/bg_journal_history_locket_card"
        android:stateListAnimator="@null"
        app:cardBackgroundColor="#685757"
        app:cardCornerRadius="@dimen/journal_history_page_card_radius"
        app:cardElevation="0dp"
        app:cardPreventCornerOverlap="false"
        app:cardUseCompatPadding="false"
        app:layout_constraintDimensionRatio="@string/journal_history_page_card_ratio"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:strokeColor="@android:color/transparent"
        app:strokeWidth="0dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/journalHistoryImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:adjustViewBounds="false"
                android:background="@drawable/bg_journal_history_locket_card"
                android:contentDescription="@string/journal_photo_desc"
                android:scaleType="centerCrop" />

            <TextView
                android:id="@+id/journalHistoryCaption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginBottom="22dp"
                android:background="@drawable/bg_journal_preview_caption"
                android:ellipsize="end"
                android:fontFamily="@font/be_vietnam_pro_bold"
                android:gravity="center"
                android:maxLines="2"
                android:minHeight="48dp"
                android:paddingStart="22dp"
                android:paddingTop="10dp"
                android:paddingEnd="22dp"
                android:paddingBottom="10dp"
                android:textColor="@android:color/white"
                android:textSize="17sp"
                android:visibility="gone" />
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/journalHistoryMetaRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/journal_history_page_meta_top_margin"
        android:gravity="center_horizontal"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="@id/journalHistoryCard"
        app:layout_constraintStart_toStartOf="@id/journalHistoryCard"
        app:layout_constraintTop_toBottomOf="@id/journalHistoryCard">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginEnd="10dp"
            android:stateListAnimator="@null"
            app:cardBackgroundColor="#FF2A2A2C"
            app:cardCornerRadius="999dp"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/journalHistoryAvatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/home_avatar_desc"
                android:scaleType="centerCrop"
                android:src="@drawable/img_home_profile" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/journalHistoryOwnerName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/be_vietnam_pro_bold"
            android:textColor="@android:color/white"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/journalHistoryMetaSeparator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:fontFamily="@font/be_vietnam_pro_medium"
            android:text="•"
            android:textColor="#C9CDD3"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/journalHistoryTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:fontFamily="@font/be_vietnam_pro_medium"
            android:textColor="#C9CDD3"
            android:textSize="20sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
