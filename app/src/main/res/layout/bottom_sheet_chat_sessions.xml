<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/chatbot_background"
    android:orientation="vertical"
    android:paddingStart="18dp"
    android:paddingTop="18dp"
    android:paddingEnd="18dp"
    android:paddingBottom="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/plus_jakarta_sans"
            android:text="@string/chatbot_session_title"
            android:textColor="@color/chatbot_title"
            android:textSize="18sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNewChat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/be_vietnam_pro_bold"
            android:minHeight="40dp"
            android:text="@string/chatbot_new_chat"
            android:textAllCaps="false"
            android:textColor="@color/chatbot_title"
            app:backgroundTint="@color/chatbot_session_card_bg"
            app:cornerRadius="14dp"
            app:elevation="0dp"
            app:icon="@drawable/ic_chatbot_add"
            app:iconPadding="6dp"
            app:iconTint="@color/chatbot_title"
            app:strokeColor="@color/chatbot_session_card_border"
            app:strokeWidth="1dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/txtNoSessions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:fontFamily="@font/be_vietnam_pro"
        android:text="@string/chatbot_no_sessions"
        android:textColor="@color/chatbot_subtitle"
        android:textSize="13sp"
        android:visibility="gone"
        tools:visibility="visible" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChatSessions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingEnd="8dp"
        tools:itemCount="2"
        tools:listitem="@layout/item_chat_session" />

</LinearLayout>
