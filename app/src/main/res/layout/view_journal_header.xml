<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/journalTopBar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="@dimen/journal_outer_padding"
    android:paddingTop="8dp"
    android:paddingEnd="@dimen/journal_outer_padding"
    android:paddingBottom="0dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/btnJournalProfile"
        android:layout_width="@dimen/journal_header_button_size"
        android:layout_height="@dimen/journal_header_button_size"
        android:clickable="true"
        android:focusable="true"
        android:foreground="@drawable/fg_ripple_circle"
        android:stateListAnimator="@null"
        app:cardBackgroundColor="@color/journal_surface_pill"
        app:cardCornerRadius="999dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:fontFamily="@font/material_symbols_outlined"
            android:text="account_circle"
            android:textColor="@color/journal_text_primary"
            android:textSize="30sp" />
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/btnJournalFriends"
        android:layout_width="0dp"
        android:layout_height="@dimen/journal_header_pill_height"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="@drawable/fg_ripple_rounded_large"
        android:stateListAnimator="@null"
        app:cardBackgroundColor="@color/journal_surface_pill"
        app:cardCornerRadius="@dimen/journal_header_pill_radius"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnJournalChat"
        app:layout_constraintStart_toEndOf="@id/btnJournalProfile"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingEnd="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/material_symbols_outlined"
                android:text="expand_more"
                android:textColor="@color/journal_text_primary"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/txtJournalFriendCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:fontFamily="@font/manrope"
                android:text="@string/journal_history_all_friends"
                android:textColor="@color/journal_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/btnJournalChat"
        android:layout_width="@dimen/journal_header_button_size"
        android:layout_height="@dimen/journal_header_button_size"
        android:clickable="true"
        android:focusable="true"
        android:foreground="@drawable/fg_ripple_circle"
        android:stateListAnimator="@null"
        app:cardBackgroundColor="@color/journal_surface_pill"
        app:cardCornerRadius="999dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:fontFamily="@font/material_symbols_outlined"
            android:text="chat_bubble"
            android:textColor="@color/journal_text_primary"
            android:textSize="22sp" />
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
