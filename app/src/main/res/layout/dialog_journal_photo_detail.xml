<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2000000">

    <ImageView
        android:id="@+id/imgJournalPhotoFull"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:adjustViewBounds="true"
        android:contentDescription="@string/journal_photo_desc"
        android:paddingBottom="88dp"
        android:scaleType="fitCenter"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <FrameLayout
        android:id="@+id/btnJournalPhotoClose"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="20dp"
        android:background="@drawable/bg_camera_bottom_icon"
        android:clickable="true"
        android:focusable="true"
        android:foreground="@drawable/fg_ripple_circle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:fontFamily="@font/material_symbols_outlined"
            android:fontVariationSettings="'wght' 600"
            android:text="close"
            android:textColor="@android:color/white"
            android:textSize="24sp" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/journalPhotoInfoPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_journal_photo_detail_panel"
        android:elevation="12dp"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="16dp"
        android:paddingEnd="20dp"
        android:paddingBottom="18dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <View
            android:layout_width="42dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_edit_profile_handle" />

        <TextView
            android:id="@+id/txtJournalPhotoTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/be_vietnam_pro_bold"
            android:text="Thông tin ảnh"
            android:textColor="@color/on_surface"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/txtJournalPhotoMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/be_vietnam_pro"
            android:textColor="@color/on_surface_variant"
            android:textSize="13sp"
            android:visibility="gone" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Coolcook.EditProfile.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Ngày"
            app:endIconDrawable="@drawable/ic_edit_profile_calendar"
            app:endIconMode="custom">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edtJournalPhotoDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:cursorVisible="false"
                android:focusable="false"
                android:fontFamily="@font/be_vietnam_pro"
                android:inputType="none"
                android:textColor="@color/on_surface"
                android:textSize="15sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Coolcook.EditProfile.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Caption">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edtJournalPhotoCaption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/be_vietnam_pro"
                android:gravity="top|start"
                android:inputType="textMultiLine|textCapSentences"
                android:maxLines="3"
                android:minLines="1"
                android:textColor="@color/on_surface"
                android:textSize="15sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnJournalPhotoSave"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="14dp"
            android:fontFamily="@font/be_vietnam_pro_bold"
            android:text="Lưu thay đổi"
            android:textAllCaps="false"
            android:textColor="@color/on_primary"
            android:textSize="15sp"
            app:backgroundTint="@color/primary"
            app:cornerRadius="18dp" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
