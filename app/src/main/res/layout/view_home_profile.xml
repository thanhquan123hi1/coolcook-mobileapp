<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/profileContentContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="@dimen/profile_content_padding_horizontal"
    android:paddingTop="@dimen/profile_content_padding_top"
    android:paddingEnd="@dimen/profile_content_padding_horizontal"
    android:paddingBottom="@dimen/profile_content_padding_bottom">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgProfileAvatar"
                android:layout_width="@dimen/profile_avatar_size"
                android:layout_height="@dimen/profile_avatar_size"
                android:contentDescription="Ảnh đại diện hồ sơ"
                android:scaleType="centerCrop"
                android:src="@drawable/img_home_profile"
                app:shapeAppearanceOverlay="@style/CircleImageView"
                app:strokeColor="@color/home_avatar_border"
                app:strokeWidth="2dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtProfileName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:text="Người dùng"
                    android:textColor="@color/on_surface"
                    android:textSize="@dimen/profile_header_name_text_size"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtProfileEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:text="email@example.com"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="@dimen/profile_header_email_text_size" />
            </LinearLayout>
        </LinearLayout>

        <FrameLayout
            android:id="@+id/btnProfileEdit"
            android:layout_width="@dimen/profile_edit_button_size"
            android:layout_height="@dimen/profile_edit_button_size"
            android:background="@drawable/bg_profile_edit_button"
            android:clipToOutline="true"
            android:contentDescription="Chỉnh sửa hồ sơ"
            android:foreground="@drawable/fg_ripple_circle"
            android:clickable="true"
            android:focusable="true"
            android:outlineProvider="background">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/material_symbols_outlined"
                android:fontVariationSettings="'wght' 600"
                android:text="edit"
                android:textColor="@color/primary"
                android:textSize="26sp" />
        </FrameLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/profile_stats_card_margin_top"
        android:background="@drawable/bg_profile_stats_card"
        android:baselineAligned="false"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="@dimen/profile_stats_card_padding_horizontal"
        android:paddingTop="@dimen/profile_stats_card_padding_vertical"
        android:paddingEnd="@dimen/profile_stats_card_padding_horizontal"
        android:paddingBottom="@dimen/profile_stats_card_padding_vertical"
        android:weightSum="3">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="24"
                android:textColor="@color/primary"
                android:textSize="@dimen/profile_stats_value_text_size"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="Món đã nấu"
                android:textAllCaps="true"
                android:textColor="@color/on_surface_variant"
                android:textSize="@dimen/profile_stats_label_text_size"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="6dp"
            android:background="@color/outline_variant" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="12"
                android:textColor="@color/primary"
                android:textSize="@dimen/profile_stats_value_text_size"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="Đã lưu"
                android:textAllCaps="true"
                android:textColor="@color/on_surface_variant"
                android:textSize="@dimen/profile_stats_label_text_size"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="6dp"
            android:background="@color/outline_variant" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="8"
                android:textColor="@color/primary"
                android:textSize="@dimen/profile_stats_value_text_size"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="Bài viết"
                android:textAllCaps="true"
                android:textColor="@color/on_surface_variant"
                android:textSize="@dimen/profile_stats_label_text_size"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/profile_section_title_margin_top"
        android:fontFamily="@font/be_vietnam_pro"
        android:text="Hoạt động"
        android:textColor="@color/on_surface"
        android:textSize="@dimen/profile_section_title_text_size"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/profile_action_item_margin_top"
        android:background="@drawable/bg_profile_action_item"
        android:gravity="center_vertical"
        android:minHeight="@dimen/profile_action_item_min_height"
        android:orientation="horizontal"
        android:paddingStart="@dimen/profile_action_item_padding_horizontal"
        android:paddingEnd="@dimen/profile_action_item_padding_horizontal">

        <FrameLayout
            android:layout_width="@dimen/profile_action_icon_container_size"
            android:layout_height="@dimen/profile_action_icon_container_size"
            android:background="@drawable/bg_profile_menu_icon_circle">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/material_symbols_outlined"
                android:fontVariationSettings="'wght' 600"
                android:text="bookmark"
                android:textColor="@color/primary"
                android:textSize="@dimen/profile_action_icon_size" />
        </FrameLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/profile_action_text_margin_start"
            android:layout_weight="1"
            android:fontFamily="@font/be_vietnam_pro"
            android:text="Món ăn đã lưu"
            android:textColor="@color/on_surface"
            android:textSize="@dimen/profile_action_text_size"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/material_symbols_outlined"
            android:text="chevron_right"
            android:textColor="@color/on_surface_variant"
            android:textSize="22sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/profile_action_item_margin_top"
        android:background="@drawable/bg_profile_action_item"
        android:gravity="center_vertical"
        android:minHeight="@dimen/profile_action_item_min_height"
        android:orientation="horizontal"
        android:paddingStart="@dimen/profile_action_item_padding_horizontal"
        android:paddingEnd="@dimen/profile_action_item_padding_horizontal">

        <FrameLayout
            android:layout_width="@dimen/profile_action_icon_container_size"
            android:layout_height="@dimen/profile_action_icon_container_size"
            android:background="@drawable/bg_profile_menu_icon_circle">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/material_symbols_outlined"
                android:fontVariationSettings="'wght' 600"
                android:text="auto_stories"
                android:textColor="@color/primary"
                android:textSize="@dimen/profile_action_icon_size" />
        </FrameLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/profile_action_text_margin_start"
            android:layout_weight="1"
            android:fontFamily="@font/be_vietnam_pro"
            android:text="Nhật ký món ăn"
            android:textColor="@color/on_surface"
            android:textSize="@dimen/profile_action_text_size"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/material_symbols_outlined"
            android:text="chevron_right"
            android:textColor="@color/on_surface_variant"
            android:textSize="22sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/profile_action_item_margin_top"
        android:background="@drawable/bg_profile_action_item"
        android:gravity="center_vertical"
        android:minHeight="@dimen/profile_action_item_min_height"
        android:orientation="horizontal"
        android:paddingStart="@dimen/profile_action_item_padding_horizontal"
        android:paddingEnd="@dimen/profile_action_item_padding_horizontal">

        <FrameLayout
            android:layout_width="@dimen/profile_action_icon_container_size"
            android:layout_height="@dimen/profile_action_icon_container_size"
            android:background="@drawable/bg_profile_menu_icon_circle">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/material_symbols_outlined"
                android:fontVariationSettings="'FILL' 1, 'wght' 600"
                android:text="favorite"
                android:textColor="@color/error"
                android:textSize="@dimen/profile_action_icon_size" />
        </FrameLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/profile_action_text_margin_start"
            android:layout_weight="1"
            android:fontFamily="@font/be_vietnam_pro"
            android:text="Món yêu thích"
            android:textColor="@color/on_surface"
            android:textSize="@dimen/profile_action_text_size"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/material_symbols_outlined"
            android:text="chevron_right"
            android:textColor="@color/on_surface_variant"
            android:textSize="22sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/profile_action_item_margin_top"
        android:background="@drawable/bg_profile_action_item"
        android:gravity="center_vertical"
        android:minHeight="@dimen/profile_action_item_min_height"
        android:orientation="horizontal"
        android:paddingStart="@dimen/profile_action_item_padding_horizontal"
        android:paddingEnd="@dimen/profile_action_item_padding_horizontal">

        <FrameLayout
            android:layout_width="@dimen/profile_action_icon_container_size"
            android:layout_height="@dimen/profile_action_icon_container_size"
            android:background="@drawable/bg_profile_menu_icon_circle">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/material_symbols_outlined"
                android:fontVariationSettings="'wght' 600"
                android:text="monitor_heart"
                android:textColor="@color/primary"
                android:textSize="@dimen/profile_action_icon_size" />
        </FrameLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/profile_action_text_margin_start"
            android:layout_weight="1"
            android:fontFamily="@font/be_vietnam_pro"
            android:text="Gợi ý theo sức khỏe"
            android:textColor="@color/on_surface"
            android:textSize="@dimen/profile_action_text_size"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/material_symbols_outlined"
            android:text="chevron_right"
            android:textColor="@color/on_surface_variant"
            android:textSize="22sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/profile_action_item_margin_top"
        android:background="@drawable/bg_profile_action_item"
        android:gravity="center_vertical"
        android:minHeight="@dimen/profile_action_item_min_height"
        android:orientation="horizontal"
        android:paddingStart="@dimen/profile_action_item_padding_horizontal"
        android:paddingEnd="@dimen/profile_action_item_padding_horizontal">

        <FrameLayout
            android:layout_width="@dimen/profile_action_icon_container_size"
            android:layout_height="@dimen/profile_action_icon_container_size"
            android:background="@drawable/bg_profile_menu_icon_circle">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/material_symbols_outlined"
                android:fontVariationSettings="'wght' 600"
                android:text="settings"
                android:textColor="@color/primary"
                android:textSize="@dimen/profile_action_icon_size" />
        </FrameLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/profile_action_text_margin_start"
            android:layout_weight="1"
            android:fontFamily="@font/be_vietnam_pro"
            android:text="Cài đặt"
            android:textColor="@color/on_surface"
            android:textSize="@dimen/profile_action_text_size"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/material_symbols_outlined"
            android:text="chevron_right"
            android:textColor="@color/on_surface_variant"
            android:textSize="22sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/profile_footer_section_margin_top"
        android:background="@drawable/bg_profile_action_item"
        android:gravity="center_vertical"
        android:minHeight="@dimen/profile_action_item_min_height"
        android:orientation="horizontal"
        android:paddingStart="@dimen/profile_action_item_padding_horizontal"
        android:paddingEnd="@dimen/profile_action_item_padding_horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/material_symbols_outlined"
                android:fontVariationSettings="'wght' 500"
                android:text="dark_mode"
                android:textColor="@color/on_surface_variant"
                android:textSize="@dimen/profile_action_icon_size" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/profile_action_text_margin_start"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="Chế độ tối"
                android:textColor="@color/on_surface"
                android:textSize="@dimen/profile_action_text_size"
                android:textStyle="bold" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="@dimen/profile_toggle_track_width"
            android:layout_height="@dimen/profile_toggle_track_height"
            android:background="@drawable/bg_profile_dark_mode_track"
            android:contentDescription="Trạng thái chế độ tối">

            <View
                android:layout_width="@dimen/profile_toggle_thumb_size"
                android:layout_height="@dimen/profile_toggle_thumb_size"
                android:layout_gravity="center_vertical|end"
                android:layout_marginEnd="3dp"
                android:background="@drawable/bg_profile_dark_mode_thumb" />
        </FrameLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/btnProfileLogout"
        android:layout_width="match_parent"
        android:layout_height="@dimen/profile_logout_height"
        android:layout_marginTop="@dimen/profile_logout_margin_top"
        android:background="@drawable/bg_profile_logout_button"
        android:clipToOutline="true"
        android:gravity="center"
        android:orientation="horizontal"
        android:foreground="@drawable/fg_ripple_rounded_large"
        android:clickable="true"
        android:focusable="true"
        android:outlineProvider="background">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/material_symbols_outlined"
            android:fontVariationSettings="'wght' 600"
            android:text="logout"
            android:textColor="@color/primary"
            android:textSize="28sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:fontFamily="@font/be_vietnam_pro"
            android:text="Đăng xuất"
            android:textColor="@color/primary"
            android:textSize="@dimen/profile_action_text_size"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
