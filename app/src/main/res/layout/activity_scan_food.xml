<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scanRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/recognitionSurface"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/topBar"
            android:layout_width="0dp"
            android:layout_height="@dimen/camera_screen_top_bar_height"
            android:layout_marginStart="@dimen/camera_screen_top_bar_horizontal_margin"
            android:layout_marginTop="@dimen/camera_screen_top_bar_top_margin"
            android:layout_marginEnd="@dimen/camera_screen_top_bar_horizontal_margin"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <FrameLayout
                android:id="@+id/btnBack"
                android:layout_width="@dimen/camera_screen_top_back_size"
                android:layout_height="@dimen/camera_screen_top_back_size"
                android:background="@drawable/bg_scan_camera_control_dark"
                android:clickable="true"
                android:focusable="true"
                android:foreground="@drawable/fg_ripple_circle"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_arrow_back_24"
                    app:tint="@android:color/white" />
            </FrameLayout>

            <LinearLayout
                android:id="@+id/topCenterAction"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/camera_screen_top_center_height"
                android:background="@drawable/bg_scan_camera_control_dark"
                android:gravity="center"
                android:minWidth="@dimen/camera_screen_top_center_width"
                android:orientation="horizontal"
                android:paddingStart="22dp"
                android:paddingTop="12dp"
                android:paddingEnd="22dp"
                android:paddingBottom="12dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_camera_groups" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:ellipsize="end"
                    android:fontFamily="@font/be_vietnam_pro_bold"
                    android:gravity="center"
                    android:maxLines="1"
                    android:text="1 Bạn bè"
                    android:textColor="@android:color/white"
                    android:textSize="17sp" />
            </LinearLayout>

            <FrameLayout
                android:id="@+id/topRightDecor"
                android:layout_width="@dimen/camera_screen_top_right_size"
                android:layout_height="@dimen/camera_screen_top_right_size"
                android:background="@drawable/bg_scan_camera_control_dark"
                android:foreground="@drawable/fg_ripple_circle"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_camera_chat" />
            </FrameLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <FrameLayout
            android:id="@+id/cameraPreviewCard"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="@dimen/camera_screen_preview_horizontal_margin"
            android:layout_marginTop="@dimen/camera_screen_preview_top_gap"
            android:layout_marginEnd="@dimen/camera_screen_preview_horizontal_margin"
            android:background="@drawable/bg_scan_camera_preview"
            android:clipToOutline="true"
            app:layout_constraintBottom_toTopOf="@id/footerContainer"
            app:layout_constraintDimensionRatio="424:430"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/topBar"
            app:layout_constraintVertical_bias="0">

            <androidx.camera.view.PreviewView
                android:id="@+id/previewView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:keepScreenOn="true"
                app:implementationMode="compatible"
                app:scaleType="fillCenter" />

            <View
                android:id="@+id/previewInnerFrame"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/transparent_drawable"
                android:clickable="false"
                android:focusable="false" />

            <FrameLayout
                android:id="@+id/btnFlash"
                android:layout_width="@dimen/camera_screen_flash_button_size"
                android:layout_height="@dimen/camera_screen_flash_button_size"
                android:layout_gravity="top|start"
                android:layout_marginStart="@dimen/camera_screen_flash_margin_start"
                android:layout_marginTop="@dimen/camera_screen_flash_margin_top"
                android:background="@drawable/bg_scan_camera_flash_button"
                android:clickable="true"
                android:focusable="true"
                android:foreground="@drawable/fg_ripple_circle">

                <TextView
                    android:id="@+id/iconFlash"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:fontFamily="@font/material_symbols_outlined"
                    android:text="flash_off"
                    android:textColor="@android:color/white"
                    android:textSize="20sp" />
            </FrameLayout>

            <View
                android:id="@+id/detectionBox"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:layout_marginStart="10dp"
                android:layout_marginTop="84dp"
                android:background="@drawable/bg_scan_detection_box"
                android:clickable="false"
                android:focusable="false" />

            <androidx.core.widget.NestedScrollView
                android:id="@+id/scanResultContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#F7FFF8F1"
                android:fillViewport="true"
                android:padding="18dp"
                android:scrollbars="none"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/be_vietnam_pro_medium"
                        android:text="Ảnh đã chụp"
                        android:textColor="#8F5A14"
                        android:textSize="13sp" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:layout_marginTop="10dp"
                        app:cardBackgroundColor="#FFF3E6"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="0dp">

                        <ImageView
                            android:id="@+id/imgCapturedRecognition"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:adjustViewBounds="true"
                            android:scaleType="centerCrop"
                            android:src="@drawable/img_scan_food_salad" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:fontFamily="@font/be_vietnam_pro_bold"
                        android:text="Nguyên liệu nhận diện được"
                        android:textColor="#26180F"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/txtDetectedIngredientsEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:text="Chưa có nguyên liệu nhận diện được."
                        android:textColor="#886A5341"
                        android:textSize="13sp" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/groupDetectedIngredients"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        app:chipSpacingHorizontal="8dp"
                        app:chipSpacingVertical="8dp"
                        app:singleLine="false" />

                    <TextView
                        android:id="@+id/txtExtraIngredientsLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:fontFamily="@font/be_vietnam_pro_bold"
                        android:text="Bổ sung nguyên liệu"
                        android:textColor="#26180F"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/txtExtraIngredientsHint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:text="Chọn thêm từ gợi ý hoặc tự nhập để AI ghép thành 1 món duy nhất."
                        android:textColor="#886A5341"
                        android:textSize="13sp" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/groupSuggestedExtraIngredients"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        app:chipSpacingHorizontal="8dp"
                        app:chipSpacingVertical="8dp"
                        app:singleLine="false" />

                    <TextView
                        android:id="@+id/txtSelectedExtraIngredientsLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:fontFamily="@font/be_vietnam_pro_medium"
                        android:text="Nguyên liệu bổ sung đã chọn"
                        android:textColor="#8F5A14"
                        android:textSize="13sp" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/groupSelectedExtraIngredients"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:chipSpacingHorizontal="8dp"
                        app:chipSpacingVertical="8dp"
                        app:singleLine="false" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/edtManualExtraIngredient"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/bg_food_search_input"
                            android:fontFamily="@font/be_vietnam_pro"
                            android:hint="Tự nhập nguyên liệu"
                            android:imeOptions="actionDone"
                            android:maxLines="1"
                            android:minHeight="48dp"
                            android:paddingStart="16dp"
                            android:paddingTop="12dp"
                            android:paddingEnd="16dp"
                            android:paddingBottom="12dp"
                            android:textColor="#26180F"
                            android:textColorHint="#886A5341"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/btnAddManualExtraIngredient"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:background="#E39A22"
                            android:fontFamily="@font/be_vietnam_pro_bold"
                            android:gravity="center"
                            android:minHeight="48dp"
                            android:minWidth="74dp"
                            android:paddingStart="16dp"
                            android:paddingTop="12dp"
                            android:paddingEnd="16dp"
                            android:paddingBottom="12dp"
                            android:text="Thêm"
                            android:textColor="#1A1203"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:fontFamily="@font/be_vietnam_pro_bold"
                        android:text="Lọc theo sức khỏe"
                        android:textColor="#26180F"
                        android:textSize="16sp" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:scrollbars="none">

                        <com.google.android.material.chip.ChipGroup
                            android:id="@+id/groupHealthFilters"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:chipSpacingHorizontal="8dp"
                            app:chipSpacingVertical="8dp"
                            app:singleLine="true" />
                    </HorizontalScrollView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:fontFamily="@font/be_vietnam_pro_bold"
                        android:text="Món có thể nấu"
                        android:textColor="#26180F"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/txtDishSuggestionsEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/be_vietnam_pro"
                        android:text="Chưa có món gợi ý phù hợp."
                        android:textColor="#886A5341"
                        android:textSize="13sp" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvDishSuggestions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:nestedScrollingEnabled="false" />

                    <TextView
                        android:id="@+id/txtSelectedDishHint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:fontFamily="@font/be_vietnam_pro_medium"
                        android:text="Chưa chọn món nào để lưu"
                        android:textColor="#8F5A14"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/btnSaveSelectedDish"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="#E39A22"
                        android:fontFamily="@font/be_vietnam_pro_bold"
                        android:gravity="center"
                        android:minHeight="50dp"
                        android:paddingStart="16dp"
                        android:paddingTop="14dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="14dp"
                        android:text="Lưu món đã chọn"
                        android:textColor="#1A1203"
                        android:textSize="15sp" />
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>
        </FrameLayout>

        <LinearLayout
            android:id="@+id/footerContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="@dimen/camera_screen_footer_horizontal_padding"
            android:paddingTop="0dp"
            android:paddingEnd="@dimen/camera_screen_footer_horizontal_padding"
            android:paddingBottom="@dimen/camera_screen_footer_bottom_padding"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <TextView
                android:id="@+id/txtScanStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/be_vietnam_pro"
                android:gravity="center"
                android:text="Hướng camera vào món ăn rồi bấm nút chụp"
                android:textColor="#D4C5AB"
                android:textSize="13sp"
                android:visibility="gone" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/tabsContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/camera_screen_tabs_top_margin">

                <TextView
                    android:id="@+id/tabNhanDien"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="@font/be_vietnam_pro_medium"
                    android:foreground="@drawable/fg_ripple_rounded_medium"
                    android:gravity="center"
                    android:letterSpacing="0.05"
                    android:minHeight="20dp"
                    android:text="NHẬN DIỆN"
                    android:textAllCaps="true"
                    android:textColor="#D4C5AB"
                    android:textSize="14sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tabNhatKy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/camera_screen_tabs_gap"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="@font/be_vietnam_pro_bold"
                    android:foreground="@drawable/fg_ripple_rounded_medium"
                    android:gravity="center"
                    android:letterSpacing="0.05"
                    android:minHeight="20dp"
                    android:text="NHẬT KÝ"
                    android:textAllCaps="true"
                    android:textColor="#FABD00"
                    android:textSize="14sp"
                    app:layout_constraintStart_toEndOf="@id/tabNhanDien"
                    app:layout_constraintTop_toTopOf="parent" />

                <View
                    android:id="@+id/tabIndicator"
                    android:layout_width="34dp"
                    android:layout_height="2dp"
                    android:alpha="0"
                    android:background="#FABD00"
                    android:visibility="invisible"
                    app:layout_constraintEnd_toEndOf="@id/tabNhanDien"
                    app:layout_constraintStart_toStartOf="@id/tabNhanDien"
                    app:layout_constraintTop_toBottomOf="@id/tabNhanDien" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/bottomActionRow"
                android:layout_width="match_parent"
                android:layout_height="@dimen/camera_screen_shutter_outer_size"
                android:layout_marginTop="@dimen/camera_screen_controls_top_margin">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/btnGallery"
                    android:layout_width="@dimen/camera_screen_side_action_size"
                    android:layout_height="@dimen/camera_screen_side_action_size"
                    android:background="@drawable/fg_ripple_circle"
                    android:clickable="true"
                    android:contentDescription="@null"
                    android:focusable="true"
                    android:padding="6dp"
                    android:src="@drawable/ic_camera_gallery"
                    app:layout_constraintBottom_toBottomOf="@id/btnShutter"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@id/btnShutter" />

                <FrameLayout
                    android:id="@+id/btnShutter"
                    android:layout_width="@dimen/camera_screen_shutter_outer_size"
                    android:layout_height="@dimen/camera_screen_shutter_outer_size"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="@drawable/fg_ripple_circle"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <View
                        android:layout_width="@dimen/camera_screen_shutter_outer_size"
                        android:layout_height="@dimen/camera_screen_shutter_outer_size"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_camera_shutter_outer" />

                    <View
                        android:layout_width="@dimen/camera_screen_shutter_inner_size"
                        android:layout_height="@dimen/camera_screen_shutter_inner_size"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_camera_shutter_inner" />
                </FrameLayout>

                <TextView
                    android:id="@+id/btnFlipCamera"
                    android:layout_width="@dimen/camera_screen_side_action_size"
                    android:layout_height="@dimen/camera_screen_side_action_size"
                    android:background="@drawable/fg_ripple_circle"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="@font/material_symbols_outlined"
                    android:gravity="center"
                    android:text="flip_camera_ios"
                    android:textColor="@android:color/white"
                    android:textSize="30sp"
                    app:layout_constraintBottom_toBottomOf="@id/btnShutter"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/btnShutter" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:id="@+id/txtHistoryTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/camera_screen_history_top_margin"
                android:drawableEnd="@drawable/ic_chevron_down"
                android:drawablePadding="6dp"
                android:fontFamily="@font/be_vietnam_pro_bold"
                android:text="     Lịch sử "
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <FrameLayout
        android:id="@+id/captureSaveOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E6000000"
        android:clickable="true"
        android:focusable="true"
        android:paddingStart="20dp"
        android:paddingTop="28dp"
        android:paddingEnd="20dp"
        android:paddingBottom="20dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:stateListAnimator="@null"
                app:cardBackgroundColor="#FF111111"
                app:cardCornerRadius="42dp"
                app:cardElevation="0dp">

                <ImageView
                    android:id="@+id/imgCapturePreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:adjustViewBounds="false"
                    android:contentDescription="@string/journal_photo_desc"
                    android:scaleType="centerCrop" />
            </com.google.android.material.card.MaterialCardView>

            <EditText
                android:id="@+id/edtCaptureCaption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_locket_input"
                android:fontFamily="@font/be_vietnam_pro"
                android:hint="Viết caption ngắn..."
                android:imeOptions="actionDone"
                android:maxLength="180"
                android:maxLines="3"
                android:minHeight="58dp"
                android:paddingStart="18dp"
                android:paddingTop="16dp"
                android:paddingEnd="18dp"
                android:paddingBottom="16dp"
                android:textColor="#FFFFFFFF"
                android:textColorHint="#80FFFFFF" />

            <TextView
                android:id="@+id/txtCaptureUploadProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/be_vietnam_pro"
                android:textColor="#B3FFFFFF"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/txtCaptureSaveError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="@font/be_vietnam_pro_medium"
                android:textColor="#FFFF8A80"
                android:textSize="13sp"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnCaptureSaveCancel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_locket_secondary_button"
                    android:fontFamily="@font/manrope"
                    android:gravity="center"
                    android:minHeight="54dp"
                    android:paddingStart="18dp"
                    android:paddingTop="14dp"
                    android:paddingEnd="18dp"
                    android:paddingBottom="14dp"
                    android:text="Hủy"
                    android:textColor="#FFFFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnCaptureSaveConfirm"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_locket_primary_button"
                    android:fontFamily="@font/manrope"
                    android:gravity="center"
