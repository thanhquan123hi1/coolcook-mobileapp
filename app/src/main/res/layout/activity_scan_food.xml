<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scanRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#990A0A0A"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingTop="16dp"
        android:paddingEnd="24dp"
        android:paddingBottom="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/fg_ripple_circle"
            android:stateListAnimator="@null"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="999dp"
            app:cardElevation="0dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/material_symbols_outlined"
                android:text="arrow_back"
                android:textColor="#E2E2E2"
                android:textSize="24sp" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/manrope"
            android:gravity="center"
            android:letterSpacing="0.14"
            android:text="COOLCOOK"
            android:textAllCaps="true"
            android:textColor="#E2E2E2"
            android:textSize="14sp"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnFlash"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="@drawable/fg_ripple_circle"
            android:stateListAnimator="@null"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="999dp"
            app:cardElevation="0dp">

            <TextView
                android:id="@+id/iconFlash"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/material_symbols_outlined"
                android:text="flash_on"
                android:textColor="#FABD00"
                android:textSize="24sp" />
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cameraPreviewCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="24dp"
        android:clipToPadding="false"
        android:stateListAnimator="@null"
        app:cardBackgroundColor="#1F1F1F"
        app:cardCornerRadius="48dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toTopOf="@id/footerContainer"
        app:layout_constraintDimensionRatio="3:4"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintVertical_bias="0.5"
        app:strokeColor="#264F4632"
        app:strokeWidth="1dp">

        <androidx.camera.view.PreviewView
            android:id="@+id/previewView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:keepScreenOn="true"
            app:implementationMode="performance"
            app:scaleType="fillCenter" />

        <View
            android:id="@+id/previewInnerFrame"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="48dp"
            android:background="@drawable/bg_scan_preview_frame"
            android:clickable="false"
            android:focusable="false" />

        <View
            android:id="@+id/detectionBox"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center"
            android:layout_marginStart="10dp"
            android:layout_marginTop="84dp"
            android:background="@drawable/bg_scan_detection_box"
            android:clickable="false"
            android:focusable="false" />

        <LinearLayout
            android:id="@+id/journalOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#BF0A0A0A"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical"
            android:padding="20dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope"
                android:letterSpacing="0.06"
                android:text="NHẬT KÝ MÓN NGON"
                android:textAllCaps="true"
                android:textColor="#FABD00"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="Lưu khoảnh khắc món ăn như nhật ký ảnh"
                android:textColor="#C9C9C9"
                android:textSize="12sp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvJournalMoments"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="12dp"
                android:layout_weight="1"
                android:overScrollMode="never"
                android:scrollbars="none" />

            <TextView
                android:id="@+id/txtJournalEmptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:paddingTop="12dp"
                android:text="Chưa có khoảnh khắc nào. Bấm chụp để lưu món ăn đầu tiên."
                android:textColor="#E2E2E2"
                android:textSize="13sp"
                android:visibility="gone" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/footerContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="16dp"
        android:paddingEnd="24dp"
        android:paddingBottom="48dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/txtScanStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:fontFamily="@font/be_vietnam_pro"
            android:gravity="center"
            android:text="Hướng camera vào món ăn rồi bấm nút chụp"
            android:textColor="#D4C5AB"
            android:textSize="13sp" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/tabsContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp">

            <TextView
                android:id="@+id/tabNhanDien"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="@font/manrope"
                android:foreground="@drawable/fg_ripple_rounded_medium"
                android:gravity="center"
                android:letterSpacing="0.06"
                android:minHeight="36dp"
                android:paddingStart="12dp"
                android:paddingTop="8dp"
                android:paddingEnd="12dp"
                android:paddingBottom="8dp"
                android:text="NHẬN DIỆN"
                android:textAllCaps="true"
                android:textColor="#FABD00"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tabNhatKy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="@font/manrope"
                android:foreground="@drawable/fg_ripple_rounded_medium"
                android:gravity="center"
                android:letterSpacing="0.06"
                android:minHeight="36dp"
                android:paddingStart="12dp"
                android:paddingTop="8dp"
                android:paddingEnd="12dp"
                android:paddingBottom="8dp"
                android:text="NHẬT KÝ"
                android:textAllCaps="true"
                android:textColor="#99D4C5AB"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/tabNhanDien"
                app:layout_constraintTop_toTopOf="parent" />

            <View
                android:id="@+id/tabIndicator"
                android:layout_width="34dp"
                android:layout_height="2dp"
                android:background="#FABD00"
                app:layout_constraintEnd_toEndOf="@id/tabNhanDien"
                app:layout_constraintStart_toStartOf="@id/tabNhanDien"
                app:layout_constraintTop_toBottomOf="@id/tabNhanDien" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/bottomActionRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnGallery"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="@drawable/fg_ripple_circle"
                android:stateListAnimator="@null"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="999dp"
                app:cardElevation="0dp"
                app:layout_constraintBottom_toBottomOf="@id/btnShutter"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/btnShutter"
                app:strokeColor="#4D4F4632"
                app:strokeWidth="1dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/img_scan_food_salad" />
            </com.google.android.material.card.MaterialCardView>

            <FrameLayout
                android:id="@+id/btnShutter"
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="@drawable/fg_ripple_circle"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <View
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_camera_shutter_outer" />

                <View
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_camera_shutter_inner" />
            </FrameLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnFlipCamera"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="@drawable/fg_ripple_circle"
                android:stateListAnimator="@null"
                app:cardBackgroundColor="#1F1F1F"
                app:cardCornerRadius="999dp"
                app:cardElevation="0dp"
                app:layout_constraintBottom_toBottomOf="@id/btnShutter"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/btnShutter">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:fontFamily="@font/material_symbols_outlined"
                    android:text="flip_camera_ios"
                    android:textColor="#D4C5AB"
                    android:textSize="22sp" />
            </com.google.android.material.card.MaterialCardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
