<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scanRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/recognitionSurface"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000">

        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="#990A0A0A"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="24dp"
            android:paddingTop="16dp"
            android:paddingEnd="24dp"
            android:paddingBottom="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="@drawable/fg_ripple_circle"
                android:stateListAnimator="@null"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="999dp"
                app:cardElevation="0dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:fontFamily="@font/material_symbols_outlined"
                    android:text="arrow_back"
                    android:textColor="#E2E2E2"
                    android:textSize="24sp" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/manrope"
                android:gravity="center"
                android:letterSpacing="0.14"
                android:text="COOLCOOK"
                android:textAllCaps="true"
                android:textColor="#E2E2E2"
                android:textSize="14sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnFlash"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="@drawable/fg_ripple_circle"
                android:stateListAnimator="@null"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="999dp"
                app:cardElevation="0dp">

                <TextView
                    android:id="@+id/iconFlash"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:fontFamily="@font/material_symbols_outlined"
                    android:text="flash_on"
                    android:textColor="#FABD00"
                    android:textSize="24sp" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cameraPreviewCard"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="24dp"
            android:clipToPadding="false"
            android:stateListAnimator="@null"
            app:cardBackgroundColor="#1F1F1F"
            app:cardCornerRadius="48dp"
            app:cardElevation="0dp"
            app:layout_constraintBottom_toTopOf="@id/footerContainer"
            app:layout_constraintDimensionRatio="3:4"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/topBar"
            app:layout_constraintVertical_bias="0.5"
            app:strokeColor="#264F4632"
            app:strokeWidth="1dp">

            <androidx.camera.view.PreviewView
                android:id="@+id/previewView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:keepScreenOn="true"
                app:implementationMode="performance"
                app:scaleType="fillCenter" />

            <View
                android:id="@+id/previewInnerFrame"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="48dp"
                android:background="@drawable/bg_scan_preview_frame"
                android:clickable="false"
                android:focusable="false" />

            <View
                android:id="@+id/detectionBox"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:layout_marginStart="10dp"
                android:layout_marginTop="84dp"
                android:background="@drawable/bg_scan_detection_box"
                android:clickable="false"
                android:focusable="false" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:id="@+id/footerContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="16dp"
            android:paddingEnd="24dp"
            android:paddingBottom="48dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <TextView
                android:id="@+id/txtScanStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/be_vietnam_pro"
                android:gravity="center"
                android:text="Hướng camera vào món ăn rồi bấm nút chụp"
                android:textColor="#D4C5AB"
                android:textSize="13sp" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/tabsContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp">

                <TextView
                    android:id="@+id/tabNhanDien"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="@font/manrope"
                    android:foreground="@drawable/fg_ripple_rounded_medium"
                    android:gravity="center"
                    android:letterSpacing="0.06"
                    android:minHeight="36dp"
                    android:paddingStart="12dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="8dp"
                    android:text="NHẬN DIỆN"
                    android:textAllCaps="true"
                    android:textColor="#FABD00"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tabNhatKy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="@font/manrope"
                    android:foreground="@drawable/fg_ripple_rounded_medium"
                    android:gravity="center"
                    android:letterSpacing="0.06"
                    android:minHeight="36dp"
                    android:paddingStart="12dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="8dp"
                    android:text="NHẬT KÝ"
                    android:textAllCaps="true"
                    android:textColor="#99D4C5AB"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@id/tabNhanDien"
                    app:layout_constraintTop_toTopOf="parent" />

                <View
                    android:id="@+id/tabIndicator"
                    android:layout_width="34dp"
                    android:layout_height="2dp"
                    android:background="#FABD00"
                    app:layout_constraintEnd_toEndOf="@id/tabNhanDien"
                    app:layout_constraintStart_toStartOf="@id/tabNhanDien"
                    app:layout_constraintTop_toBottomOf="@id/tabNhanDien" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/bottomActionRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnGallery"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="@drawable/fg_ripple_circle"
                    android:stateListAnimator="@null"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardCornerRadius="999dp"
                    app:cardElevation="0dp"
                    app:layout_constraintBottom_toBottomOf="@id/btnShutter"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@id/btnShutter"
                    app:strokeColor="#4D4F4632"
                    app:strokeWidth="1dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/img_scan_food_salad" />
                </com.google.android.material.card.MaterialCardView>

                <FrameLayout
                    android:id="@+id/btnShutter"
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="@drawable/fg_ripple_circle"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <View
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_camera_shutter_outer" />

                    <View
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_camera_shutter_inner" />
                </FrameLayout>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnFlipCamera"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="@drawable/fg_ripple_circle"
                    android:stateListAnimator="@null"
                    app:cardBackgroundColor="#1F1F1F"
                    app:cardCornerRadius="999dp"
                    app:cardElevation="0dp"
                    app:layout_constraintBottom_toBottomOf="@id/btnShutter"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/btnShutter">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:fontFamily="@font/material_symbols_outlined"
                        android:text="flip_camera_ios"
                        android:textColor="#D4C5AB"
                        android:textSize="22sp" />
                </com.google.android.material.card.MaterialCardView>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/journalSurface"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="220dp">

            <LinearLayout
                android:id="@+id/journalTopBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="20dp"
                android:paddingTop="18dp"
                android:paddingEnd="20dp"
                android:paddingBottom="12dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnJournalProfile"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="@drawable/fg_ripple_circle"
                    android:stateListAnimator="@null"
                    app:cardBackgroundColor="#FF262628"
                    app:cardCornerRadius="999dp"
                    app:cardElevation="0dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:fontFamily="@font/material_symbols_outlined"
                        android:text="account_circle"
                        android:textColor="#FFFFFFFF"
                        android:textSize="34sp" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnJournalFriends"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="14dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="@drawable/fg_ripple_rounded_large"
                    android:stateListAnimator="@null"
                    app:cardBackgroundColor="#FF2D2D30"
                    app:cardCornerRadius="999dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/material_symbols_outlined"
                            android:text="group"
                            android:textColor="#FFFFFFFF"
                            android:textSize="26sp" />

                        <TextView
                            android:id="@+id/txtJournalFriendCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:fontFamily="@font/manrope"
                            android:text="Tất cả bạn bè"
                            android:textColor="#FFFFFFFF"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:fontFamily="@font/material_symbols_outlined"
                            android:text="keyboard_arrow_down"
                            android:textColor="#FFFFFFFF"
                            android:textSize="22sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnJournalChat"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="@drawable/fg_ripple_circle"
                    android:stateListAnimator="@null"
                    app:cardBackgroundColor="#FF262628"
                    app:cardCornerRadius="999dp"
                    app:cardElevation="0dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:fontFamily="@font/material_symbols_outlined"
                        android:text="chat_bubble"
                        android:textColor="#FFFFFFFF"
                        android:textSize="30sp" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/journalCameraPreviewCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="20dp"
                android:stateListAnimator="@null"
                app:cardBackgroundColor="#FF151515"
                app:cardCornerRadius="40dp"
                app:cardElevation="0dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <androidx.camera.view.PreviewView
                        android:id="@+id/journalPreviewView"
                        android:layout_width="match_parent"
                        android:layout_height="560dp"
                        android:keepScreenOn="true"
                        app:implementationMode="performance"
                        app:scaleType="fillCenter" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnJournalFlash"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:layout_gravity="start|top"
                        android:layout_marginStart="22dp"
                        android:layout_marginTop="22dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="@drawable/fg_ripple_circle"
                        android:stateListAnimator="@null"
                        app:cardBackgroundColor="#40212123"
                        app:cardCornerRadius="999dp"
                        app:cardElevation="0dp">

                        <TextView
                            android:id="@+id/iconJournalFlash"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:fontFamily="@font/material_symbols_outlined"
                            android:text="flash_off"
                            android:textColor="#FFFFFFFF"
                            android:textSize="22sp" />
                    </com.google.android.material.card.MaterialCardView>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope"
                    android:text="Mới nhất"
                    android:textColor="#FFFFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvJournalMoments"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never"
                    android:scrollbars="none" />

                <TextView
                    android:id="@+id/txtJournalEmptyState"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_locket_empty_pill"
                    android:drawablePadding="10dp"
                    android:fontFamily="@font/manrope"
                    android:gravity="center"
                    android:minHeight="56dp"
                    android:paddingStart="22dp"
                    android:paddingTop="14dp"
                    android:paddingEnd="22dp"
                    android:paddingBottom="14dp"
                    android:text="Chưa có hoạt động nào!"
                    android:textColor="#C9CDD3"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/journalFooterContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="14dp"
        android:paddingEnd="20dp"
        android:paddingBottom="24dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/txtJournalStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:fontFamily="@font/be_vietnam_pro"
            android:gravity="center"
            android:textColor="#B3FFFFFF"
            android:textSize="13sp" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/btnJournalGallery"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:fontFamily="@font/material_symbols_outlined"
                android:gravity="center"
                android:text="photo_library"
                android:textColor="#FFFFFFFF"
                android:textSize="34sp"
                app:layout_constraintBottom_toBottomOf="@id/btnJournalShutter"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/btnJournalShutter" />

            <FrameLayout
                android:id="@+id/btnJournalShutter"
                android:layout_width="112dp"
                android:layout_height="112dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="@drawable/fg_ripple_circle"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <View
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_camera_shutter_outer" />

                <View
                    android:layout_width="76dp"
                    android:layout_height="76dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_camera_shutter_inner" />
            </FrameLayout>

            <TextView
                android:id="@+id/btnJournalFlipCamera"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:fontFamily="@font/material_symbols_outlined"
                android:gravity="center"
                android:text="flip_camera_ios"
                android:textColor="#FFFFFFFF"
                android:textSize="36sp"
                app:layout_constraintBottom_toBottomOf="@id/btnJournalShutter"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/btnJournalShutter" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/txtJournalModeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/manrope"
            android:text="Nhật ký ˅"
            android:textColor="#FFFFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/journalCaptureOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E6000000"
        android:clickable="true"
        android:focusable="true"
        android:paddingStart="20dp"
        android:paddingTop="28dp"
        android:paddingEnd="20dp"
        android:paddingBottom="20dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:stateListAnimator="@null"
                app:cardBackgroundColor="#FF111111"
                app:cardCornerRadius="42dp"
                app:cardElevation="0dp">

                <ImageView
                    android:id="@+id/imgJournalCapturedPreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:adjustViewBounds="false"
                    android:contentDescription="@string/journal_photo_desc"
                    android:scaleType="centerCrop" />
            </com.google.android.material.card.MaterialCardView>

            <EditText
                android:id="@+id/edtJournalCaption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_locket_input"
                android:fontFamily="@font/be_vietnam_pro"
                android:hint="Viết caption ngắn..."
                android:imeOptions="actionDone"
                android:maxLength="180"
                android:maxLines="3"
                android:minHeight="58dp"
                android:paddingStart="18dp"
                android:paddingTop="16dp"
                android:paddingEnd="18dp"
                android:paddingBottom="16dp"
                android:textColor="#FFFFFFFF"
                android:textColorHint="#80FFFFFF" />

            <TextView
                android:id="@+id/txtJournalUploadProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/be_vietnam_pro"
                android:textColor="#B3FFFFFF"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/txtJournalPostError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="@font/be_vietnam_pro_medium"
                android:textColor="#FFFF8A80"
                android:textSize="13sp"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnJournalPostCancel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_locket_secondary_button"
                    android:fontFamily="@font/manrope"
                    android:gravity="center"
