<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    android:background="@drawable/bg_health_form_card"
    android:elevation="9dp"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="top"
        android:orientation="horizontal">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="98dp"
            android:layout_height="98dp"
            app:cardBackgroundColor="#FFF4E7DB"
            app:cardCornerRadius="22dp"
            app:cardElevation="4dp">

            <ImageView
                android:id="@+id/imgHealthRecommendation"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_health_recommendation_image"
                android:scaleType="centerCrop"
                android:src="@drawable/img_scan_food_salad" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtHealthRecommendationName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/be_vietnam_pro_bold"
                android:textColor="#3D2B1F"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/txtHealthRecommendationReason"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="@font/be_vietnam_pro_medium"
                android:lineSpacingExtra="2dp"
                android:textColor="@color/home_text_primary"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/groupHealthRecommendationTags"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:chipSpacingHorizontal="8dp"
        app:chipSpacingVertical="6dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHealthRecommendationRecipe"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:background="@drawable/bg_health_recipe_button"
            android:elevation="4dp"
            android:fontFamily="@font/be_vietnam_pro_bold"
            android:maxLines="1"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:singleLine="true"
            android:text="Xem công thức"
            android:textAllCaps="false"
            android:textColor="@color/food_detail_title"
            android:textSize="12sp"
            app:backgroundTint="@null"
            app:cornerRadius="22dp"
            app:icon="@drawable/ic_journal_book_cute"
            app:iconGravity="textStart"
            app:iconPadding="6dp"
            app:iconTint="@color/food_detail_title" />

        <Space
            android:layout_width="10dp"
            android:layout_height="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHealthRecommendationSave"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:background="@drawable/bg_health_save_outline_button"
            android:elevation="2dp"
            android:fontFamily="@font/be_vietnam_pro_bold"
            android:maxLines="1"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:singleLine="true"
            android:text="Lưu món"
            android:textAllCaps="false"
            android:textColor="#4B32D8"
            android:textSize="12sp"
            app:backgroundTint="@null"
            app:cornerRadius="22dp"
            app:icon="@drawable/ic_bookmark_cute"
            app:iconGravity="textStart"
            app:iconPadding="6dp"
            app:iconTint="#4B32D8" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnHealthRecommendationJournal"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_health_journal_button"
        android:elevation="2dp"
        android:fontFamily="@font/be_vietnam_pro_bold"
        android:maxLines="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:singleLine="true"
        android:text="Thêm vào nhật ký món ăn"
        android:textAllCaps="false"
        android:textColor="#C83F78"
        android:textSize="12sp"
        app:backgroundTint="@null"
        app:cornerRadius="22dp"
        app:icon="@drawable/ic_journal_cute"
        app:iconGravity="textStart"
        app:iconPadding="6dp"
        app:iconTint="#C83F78" />
</LinearLayout>
