<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardDishSuggestion"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="#FFFCF8"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:strokeColor="#E6D9CA"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="top"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/imgDishSuggestion"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:background="#F2E5D8"
                android:scaleType="centerCrop"
                android:src="@drawable/img_scan_food_salad" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtDishBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="10dp"
                    android:paddingTop="5dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="5dp"
                    android:text="Có sẵn"
                    android:textColor="#235C43"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtDishName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/be_vietnam_pro_bold"
                    android:text="Tên món ăn"
                    android:textColor="#26180F"
                    android:textSize="17sp" />

                <TextView
                    android:id="@+id/txtDishConfidence"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/be_vietnam_pro_medium"
                    android:text="Độ phù hợp 90%"
                    android:textColor="#9B7A5E"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/txtDishReason"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:maxLines="3"
                    android:text="Lý do món này phù hợp"
                    android:textColor="#5E4A3B"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:fontFamily="@font/be_vietnam_pro_medium"
            android:text="Nguyên liệu khớp"
            android:textColor="#26180F"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/txtDishUsedIngredients"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/be_vietnam_pro"
            android:text="thịt gà, hành, gừng"
            android:textColor="#5E4A3B"
            android:textSize="13sp" />

        <LinearLayout
            android:id="@+id/rowDishMissingIngredients"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/be_vietnam_pro_medium"
                android:text="Nguyên liệu còn thiếu"
                android:textColor="#26180F"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/txtDishMissingIngredients"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="tiêu, nước mắm"
                android:textColor="#5E4A3B"
                android:textSize="13sp" />
        </LinearLayout>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/groupDishHealthTags"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:chipSpacingHorizontal="8dp"
            app:chipSpacingVertical="8dp"
            app:singleLine="false" />

        <TextView
            android:id="@+id/txtDishRecipePreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/be_vietnam_pro"
            android:maxLines="4"
            android:text="Tóm tắt công thức"
            android:textColor="#7A6554"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/btnDishSave"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="14dp"
            android:background="#E39A22"
            android:fontFamily="@font/be_vietnam_pro_bold"
            android:gravity="center"
            android:minWidth="96dp"
            android:paddingStart="16dp"
            android:paddingTop="10dp"
            android:paddingEnd="16dp"
            android:paddingBottom="10dp"
            android:text="Lưu món"
            android:textColor="#1A1203"
            android:textSize="13sp" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
