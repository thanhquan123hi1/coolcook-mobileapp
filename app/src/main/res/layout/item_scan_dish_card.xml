<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardDishSuggestion"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="#101010"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:strokeColor="#2A3A3A3A"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="top"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/imgDishSuggestion"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:background="#1E1E1E"
                android:scaleType="centerCrop"
                android:src="@drawable/img_scan_food_salad" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtDishBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="10dp"
                    android:paddingTop="5dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="5dp"
                    android:text="Có sẵn"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtDishName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/be_vietnam_pro_bold"
                    android:text="Tên món ăn"
                    android:textColor="#F8F5EE"
                    android:textSize="17sp" />

                <TextView
                    android:id="@+id/txtDishConfidence"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/be_vietnam_pro_medium"
                    android:text="Độ phù hợp 90%"
                    android:textColor="#B8D4C5AB"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/txtDishReason"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:maxLines="3"
                    android:text="Lý do món này phù hợp"
                    android:textColor="#D6D1C7"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/txtDishSelectedIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/material_symbols_outlined"
                android:text="check_circle"
                android:textColor="#5AFFFFFF"
                android:textSize="22sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:fontFamily="@font/be_vietnam_pro_medium"
            android:text="Nguyên liệu dùng"
            android:textColor="#F8F5EE"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/txtDishUsedIngredients"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/be_vietnam_pro"
            android:text="thịt bò, cà chua"
            android:textColor="#D6D1C7"
            android:textSize="13sp" />

        <LinearLayout
            android:id="@+id/rowDishMissingIngredients"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/be_vietnam_pro_medium"
                android:text="Nguyên liệu còn thiếu"
                android:textColor="#F8F5EE"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/txtDishMissingIngredients"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/be_vietnam_pro"
                android:text="hành, tiêu"
                android:textColor="#D6D1C7"
                android:textSize="13sp" />
        </LinearLayout>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/groupDishHealthTags"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:chipSpacingHorizontal="8dp"
            app:chipSpacingVertical="8dp"
            app:singleLine="false" />

        <TextView
            android:id="@+id/txtDishRecipePreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/be_vietnam_pro"
            android:maxLines="4"
            android:text="Tóm tắt công thức"
            android:textColor="#A8F8F5EE"
            android:textSize="12sp" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
