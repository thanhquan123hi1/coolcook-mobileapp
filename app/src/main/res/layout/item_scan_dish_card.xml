<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardDishSuggestion"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="@drawable/bg_scan_suggestion_card"
    app:cardBackgroundColor="#FFFFFBF8"
    app:cardCornerRadius="32dp"
    app:cardElevation="7dp"
    app:strokeColor="#3AE6D8CC"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="top"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="106dp"
                android:layout_height="106dp"
                app:cardBackgroundColor="#F4E7DB"
                app:cardCornerRadius="24dp"
                app:cardElevation="5dp">

                <ImageView
                    android:id="@+id/imgDishSuggestion"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_scan_suggestion_image"
                    android:scaleType="centerCrop"
                    android:src="@drawable/img_scan_food_salad" />
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtDishBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_scan_suggestion_status_local"
                    android:paddingStart="14dp"
                    android:paddingTop="7dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="7dp"
                    android:text="Có sẵn"
                    android:textColor="#3E6B48"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtDishName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/be_vietnam_pro_bold"
                    android:text="Tên món ăn"
                    android:textColor="#3A241C"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/txtDishConfidence"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:fontFamily="@font/be_vietnam_pro_bold"
                    android:text="Độ phù hợp 90%"
                    android:textColor="#F58BA8"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/txtDishReason"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="7dp"
                    android:fontFamily="@font/be_vietnam_pro"
                    android:lineSpacingExtra="2dp"
                    android:maxLines="3"
                    android:text="Lý do món này phù hợp"
                    android:textColor="#6E5648"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:fontFamily="@font/be_vietnam_pro_bold"
            android:text="Nguyên liệu khớp"
            android:textColor="#3A241C"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/txtDishUsedIngredients"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:fontFamily="@font/be_vietnam_pro"
            android:lineSpacingExtra="2dp"
            android:text="thịt gà, hành, gừng"
            android:textColor="#6E5648"
            android:textSize="13sp" />

        <LinearLayout
            android:id="@+id/rowDishMissingIngredients"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/be_vietnam_pro_bold"
                android:text="Nguyên liệu còn thiếu"
                android:textColor="#3A241C"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/txtDishMissingIngredients"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:fontFamily="@font/be_vietnam_pro"
                android:lineSpacingExtra="2dp"
                android:text="tiêu, nước mắm"
                android:textColor="#6E5648"
                android:textSize="13sp" />
        </LinearLayout>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/groupDishHealthTags"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:chipSpacingHorizontal="8dp"
            app:chipSpacingVertical="6dp"
            app:singleLine="false" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_scan_suggestion_preview"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingTop="15dp"
                android:paddingEnd="16dp"
                android:paddingBottom="15dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_flower_cute" />

                    <TextView
                        android:id="@+id/txtDishRecipePreview"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:fontFamily="@font/be_vietnam_pro_medium"
                        android:lineSpacingExtra="2dp"
                        android:maxLines="4"
                        android:text="Tóm tắt công thức"
                        android:textColor="#6E5648"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="bottom|end"
                android:layout_marginEnd="8dp"
                android:layout_marginBottom="8dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_flower_cute" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="end"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnDishJournal"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:background="@drawable/bg_scan_suggestion_button_secondary"
                android:drawableStart="@drawable/ic_journal_cute"
                android:drawablePadding="8dp"
                android:elevation="4dp"
                android:fontFamily="@font/be_vietnam_pro_bold"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="Vào nhật ký"
                android:textColor="#4C3529"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/btnDishSave"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:background="@drawable/bg_scan_suggestion_button_primary"
                android:drawableStart="@drawable/ic_save_cute"
                android:drawablePadding="8dp"
                android:elevation="5dp"
                android:fontFamily="@font/be_vietnam_pro_bold"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="Lưu món"
                android:textColor="@android:color/white"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
