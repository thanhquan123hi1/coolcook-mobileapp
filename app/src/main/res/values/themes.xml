<resources>
    <style name="CircleImageView">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="Base.Theme.Coolcook" parent="Theme.Material3.DayNight.NoActionBar">
    </style>

    <style name="Theme.Coolcook" parent="Base.Theme.Coolcook">
    </style>

    <style name="ShapeAppearance.Coolcook.AuthCard" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamilyTopLeft">rounded</item>
        <item name="cornerFamilyTopRight">rounded</item>
        <item name="cornerFamilyBottomLeft">rounded</item>
        <item name="cornerFamilyBottomRight">rounded</item>
        <item name="cornerSizeTopLeft">40dp</item>
        <item name="cornerSizeTopRight">40dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <style name="ShapeAppearance.Coolcook.HomeRecipeImage" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamilyTopLeft">rounded</item>
        <item name="cornerFamilyTopRight">rounded</item>
        <item name="cornerFamilyBottomLeft">rounded</item>
        <item name="cornerFamilyBottomRight">rounded</item>
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeTopRight">24dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <style name="ShapeAppearanceOverlay.Coolcook.CircleFab" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="Theme.Coolcook.Splash" parent="Base.Theme.Coolcook">
        <!-- Match splash layout background so launch feels like a single screen. -->
        <item name="android:windowBackground">#fff8f3</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <item name="android:windowDisablePreview">true</item>
    </style>

    <style name="Animation.Coolcook.EditProfileDialog" parent="@android:style/Animation.Dialog">
        <item name="android:windowEnterAnimation">@anim/dialog_bounce_in</item>
        <item name="android:windowExitAnimation">@anim/dialog_bounce_out</item>
    </style>

    <style name="ThemeOverlay.Coolcook.EditProfileDialog" parent="ThemeOverlay.Material3.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:windowAnimationStyle">@style/Animation.Coolcook.EditProfileDialog</item>
    </style>

    <style name="Widget.Coolcook.EditProfile.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundMode">outline</item>
        <item name="boxBackgroundColor">@color/white</item>
        <item name="boxStrokeColor">@color/outline_variant</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxCornerRadiusTopStart">18dp</item>
        <item name="boxCornerRadiusTopEnd">18dp</item>
        <item name="boxCornerRadiusBottomStart">18dp</item>
        <item name="boxCornerRadiusBottomEnd">18dp</item>
        <item name="hintTextColor">@color/primary</item>
        <item name="startIconTint">@color/on_surface_variant</item>
    </style>

    <style name="Widget.Coolcook.Home.SurfaceCard" parent="Widget.Material3.CardView.Elevated">
        <item name="android:outlineAmbientShadowColor">@color/home_shadow_ambient</item>
        <item name="android:outlineSpotShadowColor">@color/home_shadow_spot</item>
        <item name="cardElevation">@dimen/home_card_elevation</item>
        <item name="strokeColor">@color/home_card_border_soft</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.Coolcook.Home.NavLabel" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:fontFamily">@font/be_vietnam_pro_medium</item>
        <item name="android:textColor">@color/home_nav_inactive</item>
        <item name="android:textSize">@dimen/home_bottom_nav_label_text_size</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="Widget.Coolcook.Chatbot.SoftShadowCard" parent="Widget.Material3.CardView.Elevated">
        <item name="android:outlineAmbientShadowColor">@color/chatbot_shadow_ambient_soft</item>
        <item name="android:outlineSpotShadowColor">@color/chatbot_shadow_spot_soft</item>
        <item name="cardElevation">@dimen/chatbot_button_soft_elevation</item>
        <item name="strokeColor">@color/chatbot_button_stroke</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="ShapeAppearance.Coolcook.JournalCapturedPreview" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="JournalHistoryActionText" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingVertical">12dp</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:drawablePadding">16dp</item>
    </style>

    <style name="Widget.Coolcook.Health.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">#F7F7F7</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxStrokeWidthFocused">0dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="android:textColorHint">#A0A0A0</item>
    </style>
</resources>
