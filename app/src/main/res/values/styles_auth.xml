<resources>
    <style name="TextAppearance.Coolcook.Brand.Logo" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:fontFamily">@font/be_vietnam_pro</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:textSize">30sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">-0.02</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="TextAppearance.Coolcook.Brand.Title" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:fontFamily">@font/be_vietnam_pro</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textSize">34sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:lineHeight">40sp</item>
        <item name="android:letterSpacing">-0.01</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="TextAppearance.Coolcook.Brand.Subtitle" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:fontFamily">@font/be_vietnam_pro</item>
        <item name="android:textColor">@color/on_surface_variant</item>
        <item name="android:textSize">15sp</item>
        <item name="android:lineHeight">22sp</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="TextAppearance.Coolcook.Auth.Label" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:fontFamily">@font/be_vietnam_pro_medium</item>
        <item name="android:textColor">@color/on_surface_variant</item>
        <item name="android:textSize">13sp</item>
        <item name="android:lineHeight">18sp</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="TextAppearance.Coolcook.Auth.Button" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:fontFamily">@font/be_vietnam_pro_medium</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="TextAppearance.Coolcook.Auth.Link" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:fontFamily">@font/be_vietnam_pro_medium</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="TextAppearance.Coolcook.Auth.DividerLabel" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:fontFamily">@font/be_vietnam_pro_medium</item>
        <item name="android:textColor">@color/on_surface_variant</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="TextAppearance.Coolcook.Auth.SocialLabel" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:fontFamily">@font/be_vietnam_pro_medium</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textSize">15sp</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="TextAppearance.Coolcook.Auth.Error" parent="TextAppearance.Material3.BodySmall">
        <item name="android:fontFamily">@font/be_vietnam_pro</item>
        <item name="android:textColor">@color/auth_input_error</item>
        <item name="android:textSize">12sp</item>
        <item name="android:lineHeight">16sp</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="Widget.Coolcook.Auth.SheetCard" parent="Widget.Material3.CardView.Elevated">
        <item name="android:outlineAmbientShadowColor">@color/home_shadow_ambient</item>
        <item name="android:outlineSpotShadowColor">@color/home_shadow_spot</item>
        <item name="cardElevation">2dp</item>
    </style>

    <style name="Widget.Coolcook.Auth.SocialCard" parent="Widget.Material3.CardView.Elevated">
        <item name="android:outlineAmbientShadowColor">@color/home_shadow_ambient</item>
        <item name="android:outlineSpotShadowColor">@color/home_shadow_spot</item>
        <item name="cardBackgroundColor">@color/surface_container_lowest</item>
        <item name="cardCornerRadius">18dp</item>
        <item name="cardElevation">1.5dp</item>
        <item name="strokeColor">@color/home_card_border_soft</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.Coolcook.Auth.PrimaryButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_btn_login</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="android:fontFamily">@font/be_vietnam_pro_medium</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:elevation">4dp</item>
        <item name="android:outlineAmbientShadowColor">@color/home_shadow_ambient</item>
        <item name="android:outlineSpotShadowColor">@color/home_shadow_spot</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="Widget.Coolcook.Auth.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundMode">outline</item>
        <item name="boxBackgroundColor">@color/surface_container_lowest</item>
        <item name="boxStrokeColor">@color/auth_input_stroke</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxStrokeErrorColor">@color/auth_input_error</item>
        <item name="boxCornerRadiusTopStart">20dp</item>
        <item name="boxCornerRadiusTopEnd">20dp</item>
        <item name="boxCornerRadiusBottomStart">20dp</item>
        <item name="boxCornerRadiusBottomEnd">20dp</item>
        <item name="errorEnabled">true</item>
        <item name="errorTextAppearance">@style/TextAppearance.Coolcook.Auth.Error</item>
        <item name="errorTextColor">@color/auth_input_error</item>
        <item name="endIconTint">@color/on_surface_variant</item>
        <item name="hintEnabled">false</item>
    </style>

    <style name="Widget.Coolcook.Auth.TextInputEditText" parent="Widget.Material3.TextInputEditText.OutlinedBox">
        <item name="android:background">@null</item>
        <item name="android:fontFamily">@font/be_vietnam_pro</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textColorHint">@color/auth_input_hint</item>
        <item name="android:textSize">15sp</item>
        <item name="android:lineHeight">20sp</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:paddingStart">2dp</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingEnd">2dp</item>
        <item name="android:paddingBottom">16dp</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="Widget.Coolcook.Auth.Checkbox" parent="Widget.AppCompat.CompoundButton.CheckBox">
        <item name="android:button">@drawable/selector_auth_checkbox</item>
        <item name="android:fontFamily">@font/be_vietnam_pro</item>
        <item name="android:textColor">@color/on_surface_variant</item>
        <item name="android:textSize">14sp</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:minHeight">32dp</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
    </style>
</resources>
