<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="999dp" />
            <gradient
                android:centerX="0.5"
                android:centerY="0.68"
                android:endColor="@android:color/transparent"
                android:gradientRadius="120dp"
                android:startColor="@color/chatbot_soft_shadow_start"
                android:centerColor="@color/chatbot_soft_shadow_mid"
                android:type="radial" />
        </shape>
    </item>

    <item
        android:left="2dp"
        android:top="1dp"
        android:right="2dp"
        android:bottom="3dp">
        <shape android:shape="rectangle">
            <corners android:radius="999dp" />
            <solid android:color="@color/chatbot_upload_bg" />
            <stroke
                android:width="1dp"
                android:color="@color/chatbot_upload_border" />
        </shape>
    </item>
</layer-list>