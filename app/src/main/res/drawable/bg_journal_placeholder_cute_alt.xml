<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFEBD6" />
            <corners android:radius="16dp" />
            <stroke
                android:width="1dp"
                android:color="#33D79F68" />
        </shape>
    </item>

    <item
        android:gravity="center"
        android:width="20dp"
        android:height="20dp">
        <shape android:shape="oval">
            <solid android:color="#33FFFFFF" />
        </shape>
    </item>

    <item
        android:gravity="center"
        android:width="14dp"
        android:height="14dp"
        android:drawable="@drawable/ic_journal_plus_brown" />
</layer-list>
