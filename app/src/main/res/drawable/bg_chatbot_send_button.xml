<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="oval">
            <gradient
                android:centerX="0.5"
                android:centerY="0.64"
                android:endColor="@android:color/transparent"
                android:gradientRadius="32dp"
                android:startColor="@color/chatbot_soft_shadow_start"
                android:centerColor="@color/chatbot_soft_shadow_mid"
                android:type="radial" />
        </shape>
    </item>

    <item
        android:left="2dp"
        android:top="1dp"
        android:right="2dp"
        android:bottom="3dp">
        <shape android:shape="oval">
            <solid android:color="@color/black" />
        </shape>
    </item>
</layer-list>