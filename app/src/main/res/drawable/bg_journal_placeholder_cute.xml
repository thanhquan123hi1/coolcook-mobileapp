<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFF2E3" />
            <corners android:radius="16dp" />
            <stroke
                android:width="1dp"
                android:color="#33C18A55" />
        </shape>
    </item>

    <item
        android:gravity="center"
        android:width="20dp"
        android:height="20dp"
        android:drawable="@drawable/ic_journal_diary_soft" />

    <item
        android:gravity="bottom|end"
        android:end="2dp"
        android:bottom="2dp"
        android:width="14dp"
        android:height="14dp"
        android:drawable="@drawable/ic_journal_plus_brown" />
</layer-list>
