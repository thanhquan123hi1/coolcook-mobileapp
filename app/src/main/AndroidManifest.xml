<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Coolcook">

        <meta-data
            android:name="com.facebook.sdk.ApplicationId"
            android:value="@string/facebook_app_id" />

        <meta-data
            android:name="com.facebook.sdk.ClientToken"
            android:value="@string/facebook_client_token" />

        <activity
            android:name="com.facebook.FacebookActivity"
            android:configChanges="keyboard|keyboardHidden|screenLayout|screenSize|orientation"
            android:label="@string/app_name" />

        <activity
            android:name="com.facebook.CustomTabActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data android:scheme="@string/fb_login_protocol_scheme" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.splash.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.Coolcook.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <activity
            android:name=".ui.main.MainActivity"
            android:exported="false"
            android:theme="@style/Theme.Coolcook">
        </activity>

        <activity
            android:name=".ui.home.HomeActivity"
            android:exported="false"
            android:theme="@style/Theme.Coolcook" />

        <activity
            android:name=".ui.search.FoodCatalogActivity"
            android:exported="false"
            android:theme="@style/Theme.Coolcook" />

        <activity
            android:name=".ui.search.FoodDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.Coolcook" />

        <activity
            android:name=".ui.chatbot.ChatBotActivity"
            android:exported="false"
            android:theme="@style/Theme.Coolcook" />

        <activity
            android:name=".ui.journal.JournalCalendarActivity"
            android:exported="false"
            android:theme="@style/Theme.Coolcook" />

        <activity
            android:name=".ui.journal.JournalDayDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.Coolcook" />

        <activity
            android:name=".ui.scan.ScanFoodActivity"
            android:exported="false"
            android:theme="@style/Theme.Coolcook" />

        <activity
            android:name=".ui.auth.AuthActivity"
            android:exported="false"
            android:theme="@style/Theme.Coolcook" />
    </application>

</manifest>
