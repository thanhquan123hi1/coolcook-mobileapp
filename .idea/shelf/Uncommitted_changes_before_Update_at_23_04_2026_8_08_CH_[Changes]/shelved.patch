\n                android:layout_marginTop=\"10dp\"\r\n                android:layout_marginEnd=\"10dp\"\r\n                android:background=\"@drawable/bg_food_icon_circle_light\"\r\n                android:fontFamily=\"@font/material_symbols_outlined\"\r\n                android:fontVariationSettings=\"'FILL' 1, 'wght' 600\"\r\n                android:gravity=\"center\"\r\n                android:text=\"favorite\"\r\n                android:textColor=\"@color/error\"\r\n                android:textSize=\"18sp\"\r\n                android:visibility=\"gone\"\r\n                tools:visibility=\"visible\" />\r\n\r\n            <TextView\r\n                android:id=\"@+id/txtFoodCookTime\"\r\n                android:layout_width=\"wrap_content\"\r\n                android:layout_height=\"28dp\"\r\n                android:layout_gravity=\"bottom|end\"\r\n                android:layout_marginEnd=\"10dp\"\r\n                android:layout_marginBottom=\"10dp\"\r\n                android:background=\"@drawable/bg_food_time_badge\"\r\n                android:fontFamily=\"@font/be_vietnam_pro_bold\"\r\n                android:gravity=\"center\"\r\n                android:includeFontPadding=\"false\"\r\n                android:minWidth=\"64dp\"\r\n                android:paddingStart=\"10dp\"\r\n                android:paddingEnd=\"10dp\"\r\n                android:textColor=\"@color/on_surface\"\r\n                android:textSize=\"11sp\"\r\n                tools:text=\"45 MIN\" />\r\n        </FrameLayout>\r\n\r\n        <TextView\r\n            android:id=\"@+id/txtFoodName\"\r\n            android:layout_width=\"match_parent\"\r\n            android:layout_height=\"wrap_content\"\r\n            android:layout_marginStart=\"12dp\"\r\n            android:layout_marginTop=\"12dp\"\r\n            android:layout_marginEnd=\"12dp\"\r\n            android:ellipsize=\"end\"\r\n            android:fontFamily=\"@font/be_vietnam_pro_bold\"\r\n            android:maxLines=\"2