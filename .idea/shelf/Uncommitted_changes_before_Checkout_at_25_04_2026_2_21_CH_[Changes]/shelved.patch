+    @NonNull
+    private String normalizeHealth(@NonNull String input) {
+        String ascii = Normalizer.normalize(input, Normalizer.Form.NFD)
+                .replaceAll("\\p{M}+", "")
+                .replace('đ', 'd')
+                .replace('Đ', 'D');
+        return ascii.toLowerCase(Locale.ROOT)
+                .replaceAll("[^a-z0-9\\s]", " ")
+                .replaceAll("\\s+", " ")
+                .trim();
+    }
+
+    private boolean containsAnalysisTag(@NonNull HealthAnalysisResult analysis, @NonNull String target) {
+        String normalizedTarget = normalizeHealth(target);
+        for (String tag : analysis.getTags()) {
+            String normalizedTag = normalizeHealth(tag);
+            if (normalizedTag.contains(normalizedTarget) || normalizedTarget.contains(normalizedTag)) {
+                return true;
+            }
+        }
+        return false;
+    }
+
+    private boolean areNearHealthTags(@NonNull String left, @NonNull String right) {
+        return (left.contains("mo nhiem mau") && right.contains("han che dau mo"))
+                || (right.contains("mo nhiem mau") && left.contains("han che dau mo"))
+                || (left.contains("an thanh dam") && right.contains("an nhat"))
+                || (right.contains("an thanh dam") && left.contains("an nhat"))
+                || (left.contains("an nhe bung") && right.contains("de tieu"))
+                || (right.contains("an nhe bung") && left.contains("de tieu"));
+    }
