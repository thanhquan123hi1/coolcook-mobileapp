+    private void applyHealthProfileToSuggestions(
+            @NonNull List<ScanDishItem> dishItems,
+            @NonNull String sourceLabel) {
+        FirebaseUser user = FirebaseAuth.getInstance().getCurrentUser();
+        if (user == null || healthProfileRepository == null) {
+            currentHealthAnalysis = null;
+            suggestionDialogTitle = "AI gợi ý món từ thực phẩm của bạn";
+            finalizeSuggestionDisplay(rankAndLimitDishItems(dishItems), sourceLabel);
+            return;
+        }
+
+        healthProfileRepository.loadHealthProfile(user.getUid(), (profile, error) -> runOnUiThread(() -> {
+            if (profile == null) {
+                currentHealthAnalysis = null;
+                suggestionDialogTitle = "AI gợi ý món từ thực phẩm của bạn";
+                finalizeSuggestionDisplay(rankAndLimitDishItems(dishItems), sourceLabel);
+                return;
+            }
+
+            currentHealthAnalysis = HealthAnalyzer.analyze(profile);
+            suggestionDialogTitle = "Món có thể phù hợp với sức khỏe của bạn";
+            finalizeSuggestionDisplay(rankByHealth(dishItems, currentHealthAnalysis), sourceLabel);
+        }));
+    }
+
+    @NonNull
+    private List<ScanDishItem> rankByHealth(
+            @NonNull List<ScanDishItem> dishItems,
+            @NonNull HealthAnalysisResult analysis) {
+        List<ScoredSuggestion> scoredSuggestions = new ArrayList<>();
+        for (ScanDishItem item : dishItems) {
+            int score = 0;
+            for (String tag : item.getHealthTags()) {
+                String normalizedTag = normalizeHealth(tag);
+                for (String analysisTag : analysis.getTags()) {
+                    String normalizedAnalysisTag = normalizeHealth(analysisTag);
+                    if (normalizedTag.equals(normalizedAnalysisTag)) {
+                        score += 3;
+                    } else if (normalizedTag.contains(normalizedAnalysisTag)
+                            || normalizedAnalysisTag.contains(normalizedTag)
+                            || areNearHealthTags(normalizedTag, normalizedAnalysisTag)) {
+                        score += 2;
+                    }
+                }
+            }
+
+            String recipe = normalizeHealth(item.getRecipe());
+            if (containsAnalysisTag(analysis, "huyết áp cao") || containsAnalysisTag(analysis, "nhịp tim cao")) {
+                if (recipe.contains("dau dieu") || recipe.contains("gio heo")
+                        || recipe.contains("mam ruoc") || recipe.contains("nhieu muoi")) {
+                    score -= 3;
+                }
+                if (recipe.contains("ot") || recipe.contains("sa te")) {
+                    score -= 2;
+                }
+            }
+            scoredSuggestions.add(new ScoredSuggestion(item, score));
+        }
+
+        scoredSuggestions.sort(Comparator
+                .comparingInt(ScoredSuggestion::getScore).reversed()
+                .thenComparingDouble(item -> item.item.getConfidence()).reversed()
+                .thenComparing(item -> item.item.getName(), String.CASE_INSENSITIVE_ORDER));
+
+        List<ScanDishItem> ranked = new ArrayList<>();
+        boolean hasPositive = false;
+        for (ScoredSuggestion suggestion : scoredSuggestions) {
+            if (suggestion.score > 0) {
+                hasPositive = true;
+                break;
+            }
+        }
+
+        for (ScoredSuggestion suggestion : scoredSuggestions) {
+            if (hasPositive && suggestion.score < 0) {
+                continue;
+            }
+            ranked.add(suggestion.item);
+        }
+        if (ranked.isEmpty()) {
+            ranked.addAll(dishItems);
+        }
+        return rankAndLimitDishItems(ranked);
+    }
+
+    private void finalizeSuggestionDisplay(
+            @NonNull List<ScanDishItem> rankedDishItems,
+            @NonNull String sourceLabel) {
+        allSuggestedDishItems.clear();
+        allSuggestedDishItems.addAll(rankedDishItems);
+        selectedDishItem = null;
+        renderDetectedIngredients(currentDetectedIngredients);
+        applyDishFilter();
+        updateRecognitionPreviewState();
+        if (allSuggestedDishItems.isEmpty()) {
+            updateScanStatus("Chua tim thay mon phu hop");
