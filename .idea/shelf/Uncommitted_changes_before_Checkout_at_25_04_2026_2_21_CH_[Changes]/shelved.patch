+    @NonNull
+    private String inferMealType() {
+        Calendar calendar = Calendar.getInstance();
+        int hour = calendar.get(Calendar.HOUR_OF_DAY);
+        if (hour < 10) {
+            return "breakfast";
+        }
+        if (hour < 15) {
+            return "lunch";
+        }
+        if (hour < 21) {
+            return "dinner";
